"Database for apps made easy."}],"kind":"overview","title":"Meet Vein","type":"topic","role":"overview","identifier":"doc:\/\/VeinCore\/tutorials\/Table-of-Contents"},"doc://VeinCore/tutorials/VeinCore/Quick-start-Xcode#ModelContainer--ManagedObjectContext":{"type":"section","abstract":[{"text":"Install VeinCore and create your first model.","type":"text"}],"identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Quick-start-Xcode#ModelContainer--ManagedObjectContext","kind":"section","role":"pseudoSymbol","url":"\/tutorials\/veincore\/quick-start-xcode#ModelContainer--ManagedObjectContext","title":"ModelContainer & ManagedObjectContext"},"unit-test-migrations-3.swift":{"type":"file","identifier":"unit-test-migrations-3.swift","content":["import Foundation","import Testing","import VeinCore","import VeinTesting","","@MainActor","struct StepByStep {","    @Test","    func stepByStepVerification() async throws {","        let tester = try MigrationTester(migrationPlan: MigrationPlan.self)","        ","        let username = \"miakoring\"","        let bio = \"Amethyst Vein\"","        let email = \"example@amethystsoft.de\"","        ","        try tester.seed(","            version: Version1.self,","            with: { context in","                let user = Version1.User(username: username)","                let profile = Version1.Profile(bio: bio)","                ","                try context.insert(user)","                try context.insert(profile)","                try context.save()","            }","        )","        ","        try tester.migrateAndCheck(","            version: Version2.self,","            with: { context in","                let users = try context","                    .fetchAll(Version2.User.self)","                #expect(users.count == 1)","                ","                if let user = users.first {","                    #expect(user.username == username)","                    #expect(user.email == nil)","                    ","                    user.email = email","                }","                ","                let profiles = try context","                    .fetchAll(Version2.Profile.self)","                #expect(profiles.count == 1)","                ","                if let profile = profiles.first {","                    #expect(profile.bio == bio)","                }","                ","                try context.save()","            }","        )","        ","        try tester.migrateAndCheck(","            version: Version3.self,","            with: { context in","                let users = try context","                    .fetchAll(Version3.User.self)","                #expect(users.count == 1)","                ","                let profiles = try context","                    .fetchAll(Version3.Profile.self)","                #expect(profiles.count == 1)","                ","                if let profile = profiles.first {","                    #expect(profile.bio == bio)","                    #expect(profile.internalID.hasPrefix(\"ID-\"))","                    if let id = Int(profile.internalID.dropFirst(3)) {","                        #expect((1000...9999).contains(id))","                    } else {","                        Issue.record(\"Internal ID should be a number after `ID-` prefix\")","                    }","                }","            }","        )","    }","}"],"fileName":"StepByStepTest.swift","syntax":"swift","highlights":[],"fileType":"swift"},"doc://VeinCore/tutorials/VeinCore/ComplexMigrations#Writing-Custom-Migration-Logic":{"title":"Writing Custom Migration Logic","identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/ComplexMigrations#Writing-Custom-Migration-Logic","type":"section","url":"\/tutorials\/veincore\/complexmigrations#Writing-Custom-Migration-Logic","kind":"section","role":"pseudoSymbol","abstract":[{"type":"text","text":"Handle structural database transformations by fetching existing models and inserting new ones."}]},"unit-test-migrations-f-2.swift":{"content":["import Foundation","import Testing","import VeinCore","import VeinTesting","","@MainActor","struct FullChain {","    @Test","    func fullChainVerification() async throws {","        let tester = try MigrationTester(migrationPlan: MigrationPlan.self)","        ","        let username = \"miakoring\"","        let bio = \"Amethyst Vein\"","        let email = \"example@amethystsoft.de\"","        ","        try tester.testCompleteChain(","            initialData: { context in","                let user = Version1.User(username: username)","                let profile = Version1.Profile(bio: bio)","                ","                try context.insert(user)","                try context.insert(profile)","                try context.save()","            },","            validations: [","                Version3.version: { context in","                    let users = try context","                        .fetchAll(Version3.User.self)","                    #expect(users.count == 1)","                    ","                    let profiles = try context","                        .fetchAll(Version3.Profile.self)","                    #expect(profiles.count == 1)","                    ","                    if let profile = profiles.first {","                        #expect(profile.bio == bio)","                        #expect(profile.internalID.hasPrefix(\"ID-\"))","                        if let id = Int(profile.internalID.dropFirst(3)) {","                            #expect((1000...9999).contains(id))","                        } else {","                            Issue.record(\"Internal ID should be a number after `ID-` prefix\")","                        }","                    }","                }","            ]","        )","    }","}"],"type":"file","fileType":"swift","identifier":"unit-test-migrations-f-2.swift","syntax":"swift","fileName":"FullChainTest.swift","highlights":[]},"unit-test-migrations-schemas.swift":{"type":"file","identifier":"unit-test-migrations-schemas.swift","content":["import Foundation","import VeinCore","","fileprivate enum Version1: VersionedSchema {","    static let version = ModelVersion(1, 0, 0)","    static var models: [any Vein.PersistentModel.Type] {[","        User.self,","        Profile.self","    ]}","    ","    @Model","    final class User {","        @Field var username: String","        init(username: String) { self.username = username }","    }","    ","    @Model","    final class Profile {","        @Field var bio: String","        init(bio: String) { self.bio = bio }","    }","}","","fileprivate enum Version2: VersionedSchema {","    static let version = ModelVersion(1, 1, 0)","    static var models: [any Vein.PersistentModel.Type] {[","        User.self,","        Profile.self","    ]}","    ","    @Model","    final class User {","        @Field var username: String","        \/\/ Added field","        @Field var email: String?","        init(username: String, email: String?) {","            self.username = username","            self.email = email","        }","    }","    ","    @Model","    final class Profile {","        @Field var bio: String","        init(bio: String) { self.bio = bio }","    }","}","","fileprivate enum Version3: VersionedSchema {","    static let version = ModelVersion(1, 2, 0)","    static var models: [any Vein.PersistentModel.Type] {[","        User.self,","        Profile.self,","        Post.self","    ]}","    ","    @Model","    final class User {","        @Field var username: String","        @Field var email: String?","        init(username: String, email: String?) {","            self.username = username","            self.email = email","        }","    }","    ","    @Model","    final class Profile {","        @Field var bio: String","        \/\/ added field","        @Field var internalID: String","        init(bio: String, internalID: String) {","            self.bio = bio","            self.internalID = internalID","        }","    }","    ","    @Model","    final class Post {","        @Field var content: String","        init(content: String) { self.content = content }","    }","}","","fileprivate enum MigrationPlan: SchemaMigrationPlan {","    static var schemas: [any Vein.VersionedSchema.Type] {[","        Version1.self,","        Version2.self,","        Version3.self","    ]}","    ","    static var stages: [Vein.MigrationStage] {[","        v1ToV2,","        v2ToV3,","    ]}","    ","    static let v1ToV2 = Vein.MigrationStage.complex(","        fromVersion: Version1.self,","        toVersion: Version2.self,","        willMigrate: { context in","            try Version1.User.fieldsAddedMigration(to: Version2.User.self, on: context)","            try Version1.Profile.unchangedMigration(to: Version2.Profile.self, on: context)","        },","        didMigrate: nil","    )","    ","    static let v2ToV3 = Vein.MigrationStage.complex(","        fromVersion: Version2.self,","        toVersion: Version3.self,","        willMigrate: { context in","            \/\/ Basic migrations","            try Version2.User.unchangedMigration(to: Version3.User.self, on: context)","            ","            \/\/ Logic migration for Profile","            let oldProfiles = try context.fetchAll(Version2.Profile.self)","            for old in oldProfiles {","                let new = Version3.Profile(","                    bio: old.bio,","                    internalID: \"ID-\\(Int.random(in: 1000...9999))\"","                )","                try context.insert(new)","                try context.delete(old)","            }","        },","        didMigrate: nil","    )","}"],"fileName":"Schemas.swift","syntax":"swift","highlights":[],"fileType":"swift"},"doc://VeinCore/tutorials/VeinCore/SimpleMigrations#Migrating-Schemas":{"identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/SimpleMigrations#Migrating-Schemas","abstract":[{"type":"text","text":"Effortlessly & safely evolve your database schema using stage-by-stage migrations & Vein helper functions."}],"role":"pseudoSymbol","url":"\/tutorials\/veincore\/simplemigrations#Migrating-Schemas","type":"section","title":"Migrating Schemas","kind":"section"},"doc://VeinCore/tutorials/Table-of-Contents/Quick-start":{"kind":"article","type":"topic","role":"article","title":"Quick start","abstract":[],"identifier":"doc:\/\/VeinCore\/tutorials\/Table-of-Contents\/Quick-start","url":"\/tutorials\/table-of-contents\/quick-start"},"doc://VeinCore/tutorials/VeinCore/MigrationUnitTests":{"url":"\/tutorials\/veincore\/migrationunittests","abstract":[{"type":"text","text":"Migrations are a crucial and complex operation."},{"type":"text","text":" "},{"type":"text","text":"Please please please unit test your migrations, it’s incredibly important for data integrity."}],"estimatedTime":"10min","kind":"project","title":"Unit Testing Migrations","type":"topic","identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/MigrationUnitTests","role":"project"},"unit-test-migrations-2.swift":{"content":["import Foundation","import Testing","import VeinCore","import VeinTesting","","@MainActor","struct StepByStep {","    @Test","    func stepByStepVerification() async throws {","        let tester = try MigrationTester(migrationPlan: MigrationPlan.self)","        ","        let username = \"miakoring\"","        let bio = \"Amethyst Vein\"","        let email = \"example@amethystsoft.de\"","        ","        try tester.seed(","            version: Version1.self,","            with: { context in","                let user = Version1.User(username: username)","                let profile = Version1.Profile(bio: bio)","                ","                try context.insert(user)","                try context.insert(profile)","                try context.save()","            }","        )","        ","        try tester.migrateAndCheck(","            version: Version2.self,","            with: { context in","                let users = try context","                    .fetchAll(Version2.User.self)","                #expect(users.count == 1)","                ","                if let user = users.first {","                    #expect(user.username == username)","                    #expect(user.email == nil)","                    ","                    user.email = email","                }","                ","                let profiles = try context","                    .fetchAll(Version2.Profile.self)","                #expect(profiles.count == 1)","                ","                if let profile = profiles.first {","                    #expect(profile.bio == bio)","                }","                ","                try context.save()","            }","        )","    }","}"],"type":"file","fileType":"swift","identifier":"unit-test-migrations-2.swift","syntax":"swift","fileName":"StepByStepTest.swift","highlights":[]},"doc://VeinCore/tutorials/VeinCore/CustomPersistable":{"url":"\/tutorials\/veincore\/custompersistable","type":"topic","identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/CustomPersistable","role":"project","abstract":[{"type":"text","text":"Make your own types persistable."}],"estimatedTime":"5min","title":"Custom Persistable","kind":"project"},"doc://VeinCore/tutorials/VeinCore/MigrationUnitTests#Unit-Testing":{"url":"\/tutorials\/veincore\/migrationunittests#Unit-Testing","title":"Unit Testing","identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/MigrationUnitTests#Unit-Testing","role":"pseudoSymbol","abstract":[{"text":"Migrations are a crucial and complex operation.","type":"text"},{"text":" ","type":"text"},{"text":"Please please please unit test your migrations, it’s incredibly important for data integrity.","type":"text"}],"type":"section","kind":"section"},"doc://VeinCore/tutorials/VeinCore/CustomPersistable#RawRepresentable":{"kind":"section","identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/CustomPersistable#RawRepresentable","title":"RawRepres