{"kind":"project","sections":[{"content":[{"inlineContent":[{"type":"text","text":"Handle structural database transformations by fetching existing models and inserting new ones."}],"type":"paragraph"}],"title":"Complex Migrations","kind":"hero","chapter":"Complex Migrations","estimatedTimeInMinutes":7},{"kind":"tasks","tasks":[{"contentSection":[{"kind":"contentAndMedia","mediaPosition":"trailing","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Simple migration helpers are great for adding fields or dropping tables. However, when you rename fields, merge schemas, or modify non-optional data types (like mapping an "},{"code":"Int","type":"codeVoice"},{"type":"text","text":" to a formatted "},{"type":"codeVoice","code":"String"},{"type":"text","text":"), you need a custom migration."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"In this tutorial, we will migrate from "},{"code":"V0_0_1","type":"codeVoice"},{"type":"text","text":" to "},{"code":"V0_0_2","type":"codeVoice"},{"type":"text","text":" where we:"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"text":"Map an old model’s field ","type":"text"},{"code":"randomValue","type":"codeVoice"},{"text":" (Int) into a formatted ","type":"text"},{"code":"securityCode","type":"codeVoice"},{"text":" (String).","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Apply processing rules during the transfer (clamping negative numbers to zero)."}],"type":"paragraph"}]}]}]}],"title":"Writing Custom Migration Logic","anchor":"Writing-Custom-Migration-Logic","stepsSection":[{"runtimePreview":null,"media":null,"code":"complex-migration-schemas.swift","content":[{"inlineContent":[{"type":"text","text":"Define the baseline and destination schemas. Notice that "},{"type":"codeVoice","code":"V0_0_2.Test"},{"type":"text","text":" now requires a non-optional "},{"type":"codeVoice","code":"securityCode"},{"type":"text","text":" instead of "},{"type":"codeVoice","code":"randomValue"},{"type":"text","text":", meaning simple column additions won’t work."}],"type":"paragraph"}],"type":"step","caption":[]},{"media":null,"content":[{"type":"paragraph","inlineContent":[{"text":"Set up your ","type":"text"},{"code":"SchemaMigrationPlan","type":"codeVoice"},{"text":" block, preparing a ","type":"text"},{"code":".complex","type":"codeVoice"},{"text":" transition stage from version 1 to version 2.","type":"text"}]}],"code":"complex-migration-stages-1.swift","runtimePreview":null,"caption":[],"type":"step"},{"media":null,"content":[{"inlineContent":[{"type":"text","text":"Implement the migration logic. Fetch the baseline records, execute your custom business rules, and save the mapped models back to the new schema inside the transition step."}],"type":"paragraph"}],"code":"complex-migration-stages-2.swift","runtimePreview":null,"caption":[],"type":"step"}]}]}],"schemaVersion":{"patch":0,"major":0,"minor":3},"hierarchy":{"reference":"doc:\/\/VeinCore\/tutorials\/Table-of-Contents","modules":[{"projects":[{"reference":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Quick-start-Swift-Package","sections":[{"kind":"task","reference":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Quick-start-Swift-Package#Setup"},{"kind":"task","reference":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Quick-start-Swift-Package#Create-your-first-Model"},{"kind":"task","reference":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Quick-start-Swift-Package#ModelContainer--ManagedObjectContext"}]},{"reference":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Quick-start-Xcode","sections":[{"reference":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Quick-start-Xcode#Setup","kind":"task"},{"reference":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Quick-start-Xcode#Create-your-first-Model","kind":"task"},{"reference":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Quick-start-Xcode#ModelContainer--ManagedObjectContext","kind":"task"}]}],"reference":"doc:\/\/VeinCore\/tutorials\/Table-of-Contents\/Quick-s