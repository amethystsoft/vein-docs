{"sections":[{"title":"Complex Migrations","estimatedTimeInMinutes":7,"chapter":"Complex Migrations","kind":"hero","content":[{"inlineContent":[{"text":"Handle structural database transformations by fetching existing models and inserting new ones.","type":"text"}],"type":"paragraph"}]},{"kind":"tasks","tasks":[{"stepsSection":[{"code":"complex-migration-schemas.swift","runtimePreview":null,"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Define the baseline and destination schemas. Notice that "},{"type":"codeVoice","code":"V0_0_2.Test"},{"type":"text","text":" now requires a non-optional "},{"type":"codeVoice","code":"securityCode"},{"type":"text","text":" instead of "},{"type":"codeVoice","code":"randomValue"},{"type":"text","text":", meaning simple column additions won’t work."}]}],"media":null,"caption":[],"type":"step"},{"code":"complex-migration-stages-1.swift","runtimePreview":null,"content":[{"inlineContent":[{"text":"Set up your ","type":"text"},{"code":"SchemaMigrationPlan","type":"codeVoice"},{"text":" block, preparing a ","type":"text"},{"code":".complex","type":"codeVoice"},{"text":" transition stage from version 1 to version 2.","type":"text"}],"type":"paragraph"}],"media":null,"caption":[],"type":"step"},{"code":"complex-migration-stages-2.swift","runtimePreview":null,"content":[{"type":"paragraph","inlineContent":[{"text":"Implement the migration logic. Fetch the baseline records, execute your custom business rules, and save the mapped models back to the new schema inside the transition step.","type":"text"}]}],"media":null,"caption":[],"type":"step"}],"title":"Writing Custom Migration Logic","contentSection":[{"kind":"contentAndMedia","content":[{"type":"paragraph","inlineContent":[{"text":"Simple migration helpers are great for adding fields or dropping tables. However, when you rename fields, merge schemas, or modify non-optional data types (like mapping an ","type":"text"},{"code":"Int","type":"codeVoice"},{"text":" to a formatted ","type":"text"},{"code":"String","type":"codeVoice"},{"text":"), you need a custom migration.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"In this tutorial, we will migrate from ","type":"text"},{"code":"V0_0_1","type":"codeVoice"},{"text":" to ","type":"text"},{"code":"V0_0_2","type":"codeVoice"},{"text":" where we:","type":"text"}]},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"Map an old model’s field "},{"type":"codeVoice","code":"randomValue"},{"type":"text","text":" (Int) into a formatted "},{"type":"codeVoice","code":"securityCode"},{"type":"text","text":" (String)."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Apply processing rules during the transfer (clamping negative numbers to zero)."}]}]}],"type":"unorderedList"}],"mediaPosition":"trailing"}],"anchor":"Writing-Custom-Migration-Logic"}]},{"title":"Custom Persistable","featuredEyebrow":"Tutorial","abstract":[{"text":"Make your own types persistable.","type":"text"}],"kind":"callToAction","action":{"identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/CustomPersistable","overridingTitle":"Get started","isActive":true,"overridingTitleInlineContent":[{"text":"Get started","type":"text"}],"type":"reference"}}],"kind":"project","hierarchy":{"reference":"doc:\/\/VeinCore\/tutorials\/Table-of-Contents","modules":[{"projects":[{"reference":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Quick-start-Swift-Package","sections":[{"reference":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Quick-start-Swift-Package#Setup","kind":"task"},{"reference":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Quick-start-Swift-Package#Create-your-first-Model","kind":"task"},{"reference":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Quick-start-Swift-Package#ModelContainer--ManagedObjectContext","kind":"task"}]},{"reference":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Quick-start-Xcode","sections":[{"kind":"task","reference":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Quick-start-Xcode#Setup"},{"kind":"task","reference":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Quick-start-Xcode#Create-your-first-Model"},{"kind":"task","reference":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Quick-start-Xcode#ModelContainer--ManagedObjectContext"}]}],"reference":"doc:\/\/VeinCore\/tutorials\/Table-of-Contents\/Quick-start"},{"projects":[{"reference":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Relationships","sections":[{"reference":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Relationships#Adding-a-relationship-to-our-model","kind":"task"},{"reference":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Relationships#Persisting--fetching-a-relationship","kind":"task"}]}],"reference":"doc:\/\/VeinCore\/tutorials\/Table-of-Contents\/Relationships"},{"projects":[{"reference":"doc:\/\/VeinCore\/tutorials\/VeinCore\/SimpleMigrations","sections":[{"reference":"doc:\/\/VeinCore\/tutorials\/VeinCore\/SimpleMigrations#Migrating-Schemas","kind":"task"}]}],"reference":"doc:\/\/VeinCore\/tutorials\/Table-of-Contents\/Simple-Migrations"},{"projects":[{"sections":[{"reference":"doc:\/\/VeinCore\/tutorials\/VeinCore\/ComplexMigrations#Writing-Custom-Migration-Logic","kind":"task"}],"reference":"doc:\/\/VeinCore\/tutorials\/VeinCore\/ComplexMigrations"}],"reference":"doc:\/\/VeinCore\/tutorials\/Table-of-Contents\/Complex-Migrations"},{"projects":[{"sections":[{"reference":"doc:\/\/VeinCore\/tutorials\/VeinCore\/CustomPersistable#RawRepresentable","kind":"task"},{"reference":"doc:\/\/VeinCore\/tutorials\/VeinCore\/CustomPersistable#Codable","kind":"task"},{"reference":"doc:\/\/VeinCore\/tutorials\/VeinCore\/CustomPersistable#Manual-Persistable","kind":"task"}],"reference":"doc:\/\/VeinCore\/tutorials\/VeinCore\/CustomPersistable"}],"reference":"doc:\/\/VeinCore\/tutorials\/Table-of-Contents\/Custom-Persistable"},{"projects":[{"sections":[{"reference":"doc:\/\/VeinCore\/tutorials\/VeinCore\/MigrationUnitTests#The-migration-we-are-going-to-test","kind":"task"},{"reference":"doc:\/\/VeinCore\/tutorials\/VeinCore\/MigrationUnitTests#Unit-Testing","kind":"task"},{"reference":"doc:\/\/VeinCore\/tutorials\/VeinCore\/MigrationUnitTests#Unit-Testing-full-migration-chain","kind":"task"}],"reference":"doc:\/\/VeinCore\/tutorials\/VeinCore\/MigrationUnitTests"}],"reference":"doc:\/\/VeinCore\/tutorials\/Table-of-Contents\/Unit-Testing-Migrations"}],"paths":[["doc:\/\/VeinCore\/tutorials\/Table-of-Contents","doc:\/\/VeinCore\/tutorials\/Table-of-Contents\/$volume","doc:\/\/VeinCore\/tutorials\/Table-of-Contents\/Complex-Migrations"]]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/tutorials\/veincore\/complexmigrations"]}],"metadata":{"category":"Vein","title":"Complex Migrations","role":"project","categoryPathComponent":"Table-of-Contents"},"identifier":{"url":"doc:\/\/VeinCore\/tutorials\/VeinCore\/ComplexMigrations","interfaceLanguage":"swift"},"schemaVersion":{"major":0,"minor":3,"patch":0},"references":{"complex-migration-stages-1.swift":{"fileName":"Migration.swift","identifier":"complex-migration-stages-1.swift","syntax":"swift","fileType":"swift","content":["import VeinCore","","enum ComplexMigration: SchemaMigrationPlan {","    static var schemas: [any VersionedSchema.Type] {","        [V0_0_1.self, V0_0_2.self]","    }","","    static var stages: [MigrationStage] {","        [migrateV1toV2]","    }","","    static let migrateV1toV2 = MigrationStage.complex(","        fromVersion: V0_0_1.self,","        toVersion: V0_0_2.self,","        willMigrate: { context in","            \/\/ Custom mapping logic will go here","        },","        didMigrate: nil","    )","}"],"type":"file","highlights":[]},"doc://VeinCore/tutorials/Table-of-Contents/Quick-start":{"kind":"article","type":"topic","role":"article","title":"Quick start","abstract":[],"identifier":"doc:\/\/VeinCore\/tutorials\/Table-of-Contents\/Quick-start","url":"\/tutorials\/table-of-contents\/quick-start"},"doc://VeinCore/tutorials/VeinCore/Relationships":{"url":"\/tutorials\/veincore\/relationships","title":"Relationships","identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Relationships","role":"project","abstract":[{"type":"text","text":"Use relationships with VeinCore."}],"type":"topic","estimatedTime":"3min","kind":"project"},"doc://VeinCore/tutorials/VeinCore/Quick-start-Swift-Package#Create-your-first-Model":{"abstract":[{"type":"text","text":"Install VeinCore and create your first model."}],"title":"Create your first Model","role":"pseudoSymbol","identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Quick-start-Swift-Package#Create-your-first-Model","type":"section","kind":"section","url":"\/tutorials\/veincore\/quick-start-swift-package#Create-your-first-Model"},"doc://VeinCore/tutorials/Table-of-Contents/Relationships":{"kind":"article","type":"topic","role":"article","title":"Relationships","abstract":[],"identifier":"doc:\/\/VeinCore\/tutorials\/Table-of-Contents\/Relationships","url":"\/tutorials\/table-of-contents\/relationships"},"doc://VeinCore/tutorials/VeinCore/Quick-start-Swift-Package#ModelContainer--ManagedObjectContext":{"identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Quick-start-Swift-Package#ModelContainer--ManagedObjectContext","role":"pseudoSymbol","type":"section","abstract":[{"type":"text","text":"Install VeinCore and create your first model."}],"kind":"section","url":"\/tutorials\/veincore\/quick-start-swift-package#ModelContainer--ManagedObjectContext","title":"ModelContainer & ManagedObjectContext"},"doc://VeinCore/tutorials/VeinCore/Quick-start-Xcode#Create-your-first-Model":{"kind":"section","title":"Create your first Model","type":"section","abstract":[{"text":"Install VeinCore and create your first model.","type":"text"}],"url":"\/tutorials\/veincore\/quick-start-xcode#Create-your-first-Model","identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Quick-start-Xcode#Create-your-first-Model","role":"pseudoSymbol"},"doc://VeinCore/tutorials/VeinCore/MigrationUnitTests#Unit-Testing":{"url":"\/tutorials\/veincore\/migrationunittests#Unit-Testing","title":"Unit Testing","identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/MigrationUnitTests#Unit-Testing","role":"pseudoSymbol","abstract":[{"text":"Migrations are a crucial and complex operation.","type":"text"},{"text":" ","type":"text"},{"text":"Please please please unit test your migrations, it’s incredibly important for data integrity.","type":"text"}],"type":"section","kind":"section"},"doc://VeinCore/tutorials/Table-of-Contents/Custom-Persistable":{"kind":"article","identifier":"doc:\/\/VeinCore\/tutorials\/Table-of-Contents\/Custom-Persistable","title":"Custom Persistable","abstract":[],"role":"article","url":"\/tutorials\/table-of-contents\/custom-persistable","type":"topic"},"doc://VeinCore/tutorials/VeinCore/CustomPersistable#Manual-Persistable":{"kind":"section","title":"Manual Persistable","abstract":[{"type":"text","text":"Make your own types persistable."}],"url":"\/tutorials\/veincore\/custompersistable#Manual-Persistable","role":"pseudoSymbol","type":"section","identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/CustomPersistable#Manual-Persistable"},"complex-migration-stages-2.swift":{"highlights":[],"content":["import VeinCore","","enum ComplexMigration: SchemaMigrationPlan {","    static var schemas: [any VersionedSchema.Type] {","        [V0_0_1.self, V0_0_2.self]","    }","","    static var stages: [MigrationStage] {","        [migrateV1toV2]","    }","","    static let migrateV1toV2 = MigrationStage.complex(","        fromVersion: V0_0_1.self,","        toVersion: V0_0_2.self,","        willMigrate: { context in","            \/\/ 1. Fetch current models from the V1 database setup","            let oldTests = try context.fetchAll(V0_0_1.Test.self)","","            \/\/ 2. Map old entries to new types individually","            for test in oldTests {","                let sanitizedValue = max(0, test.randomValue)","","                let newTest = V0_0_2.Test(","                    flag: test.flag,","                    someValue: test.someValue,","                    securityCode: \"SEC-\\(sanitizedValue)\"","                )","","                \/\/ Add the new instance and remove the old one.","                \/\/ If a migration has unhandled non-empty tables at the end it will fail.","                try context.insert(newTest)","                try context.delete(test)","            }","        },","        didMigrate: nil","    )","}"],"type":"file","syntax":"swift","identifier":"complex-migration-stages-2.swift","fileName":"Migration.swift","fileType":"swift"},"doc://VeinCore/tutorials/VeinCore/Relationships#Persisting--fetching-a-relationship":{"kind":"section","url":"\/tutorials\/veincore\/relationships#Persisting--fetching-a-relationship","abstract":[{"type":"text","text":"Use relationships with VeinCore."}],"title":"Persisting & fetching a relationship","type":"section","role":"pseudoSymbol","identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Relationships#Persisting--fetching-a-relationship"},"doc://VeinCore/tutorials/Table-of-Contents":{"url":"\/tutorials\/table-of-contents","abstract":[{"type":"text","text":"Database for apps made easy."}],"kind":"overview","title":"Meet Vein","type":"topic","role":"overview","identifier":"doc:\/\/VeinCore\/tutorials\/Table-of-Contents"},"doc://VeinCore/tutorials/VeinCore/MigrationUnitTests#The-migration-we-are-going-to-test":{"title":"The migration we are going to test:","abstract":[{"type":"text","text":"Migrations are a crucial and complex operation."},{"type":"text","text":" "},{"type":"text","text":"Please please please unit test your migrations, it’s incredibly important for data integrity."}],"url":"\/tutorials\/veincore\/migrationunittests#The-migration-we-are-going-to-test","kind":"section","type":"section","role":"pseudoSymbol","identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/MigrationUnitTests#The-migration-we-are-going-to-test"},"doc://VeinCore/tutorials/VeinCore/MigrationUnitTests":{"url":"\/tutorials\/veincore\/migrationunittests","abstract":[{"type":"text","text":"Migrations are a crucial and complex operation."},{"type":"text","text":" "},{"type":"text","text":"Please please please unit test your migrations, it’s incredibly important for data integrity."}],"estimatedTime":"10min","kind":"project","title":"Unit Testing Migrations","type":"topic","identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/MigrationUnitTests","role":"project"},"doc://VeinCore/tutorials/VeinCore/Quick-start-Xcode":{"estimatedTime":"5min","url":"\/tutorials\/veincore\/quick-start-xcode","abstract":[{"text":"Install VeinCore and create your first model.","type":"text"}],"kind":"project","type":"topic","identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Quick-start-Xcode","role":"project","title":"Quick start Xcode"},"doc://VeinCore/tutorials/VeinCore/Quick-start-Swift-Package":{"abstract":[{"text":"Install VeinCore and create your first model.","type":"text"}],"title":"Quick start Swift Package","identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Quick-start-Swift-Package","role":"project","url":"\/tutorials\/veincore\/quick-start-swift-package","estimatedTime":"5min","type":"topic","kind":"project"},"doc://VeinCore/tutorials/VeinCore/ComplexMigrations#Writing-Custom-Migration-Logic":{"title":"Writing Custom Migration Logic","identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/ComplexMigrations#Writing-Custom-Migration-Logic","type":"section","url":"\/tutorials\/veincore\/complexmigrations#Writing-Custom-Migration-Logic","kind":"section","role":"pseudoSymbol","abstract":[{"type":"text","text":"Handle structural database transformations by fetching existing models and inserting new ones."}]},"doc://VeinCore/tutorials/VeinCore/MigrationUnitTests#Unit-Testing-full-migration-chain":{"abstract":[{"type":"text","text":"Migrations are a crucial and complex operation."},{"type":"text","text":" "},{"type":"text","text":"Please please please unit test your migrations, it’s incredibly important for data integrity."}],"type":"section","url":"\/tutorials\/veincore\/migrationunittests#Unit-Testing-full-migration-chain","identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/MigrationUnitTests#Unit-Testing-full-migration-chain","title":"Unit Testing full migration chain","kind":"section","role":"pseudoSymbol"},"doc://VeinCore/tutorials/Table-of-Contents/Simple-Migrations":{"kind":"article","type":"topic","role":"article","title":"Simple Migrations","url":"\/tutorials\/table-of-contents\/simple-migrations","abstract":[],"identifier":"doc:\/\/VeinCore\/tutorials\/Table-of-Contents\/Simple-Migrations"},"doc://VeinCore/tutorials/VeinCore/Quick-start-Swift-Package#Setup":{"title":"Setup","type":"section","role":"pseudoSymbol","kind":"section","url":"\/tutorials\/veincore\/quick-start-swift-package#Setup","identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Quick-start-Swift-Package#Setup","abstract":[{"text":"Install VeinCore and create your first model.","type":"text"}]},"doc://VeinCore/tutorials/VeinCore/CustomPersistable#RawRepresentable":{"kind":"section","identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/CustomPersistable#RawRepresentable","title":"RawRepresentable","role":"pseudoSymbol","url":"\/tutorials\/veincore\/custompersistable#RawRepresentable","type":"section","abstract":[{"text":"Make your own types persistable.","type":"text"}]},"doc://VeinCore/tutorials/Table-of-Contents/Unit-Testing-Migrations":{"kind":"article","identifier":"doc:\/\/VeinCore\/tutorials\/Table-of-Contents\/Unit-Testing-Migrations","title":"Unit Testing Migrations","abstract":[],"role":"article","url":"\/tutorials\/table-of-contents\/unit-testing-migrations","type":"topic"},"doc://VeinCore/tutorials/VeinCore/ComplexMigrations":{"abstract":[{"text":"Handle structural database transformations by fetching existing models and inserting new ones.","type":"text"}],"type":"topic","role":"project","estimatedTime":"7min","identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/ComplexMigrations","kind":"project","url":"\/tutorials\/veincore\/complexmigrations","title":"Complex Migrations"},"doc://VeinCore/tutorials/VeinCore/Relationships#Adding-a-relationship-to-our-model":{"type":"section","kind":"section","identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Relationships#Adding-a-relationship-to-our-model","abstract":[{"text":"Use relationships with VeinCore.","type":"text"}],"role":"pseudoSymbol","title":"Adding a relationship to our model","url":"\/tutorials\/veincore\/relationships#Adding-a-relationship-to-our-model"},"doc://VeinCore/tutorials/VeinCore/CustomPersistable#Codable":{"kind":"section","identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/CustomPersistable#Codable","title":"Codable","role":"pseudoSymbol","type":"section","url":"\/tutorials\/veincore\/custompersistable#Codable","abstract":[{"text":"Make your own types persistable.","type":"text"}]},"doc://VeinCore/tutorials/VeinCore/Quick-start-Xcode#ModelContainer--ManagedObjectContext":{"type":"section","abstract":[{"text":"Install VeinCore and create your first model.","type":"text"}],"identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Quick-start-Xcode#ModelContainer--ManagedObjectContext","kind":"section","role":"pseudoSymbol","url":"\/tutorials\/veincore\/quick-start-xcode#ModelContainer--ManagedObjectContext","title":"ModelContainer & ManagedObjectContext"},"doc://VeinCore/tutorials/VeinCore/SimpleMigrations#Migrating-Schemas":{"identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/SimpleMigrations#Migrating-Schemas","abstract":[{"type":"text","text":"Effortlessly & safely evolve your database schema using stage-by-stage migrations & Vein helper functions."}],"role":"pseudoSymbol","url":"\/tutorials\/veincore\/simplemigrations#Migrating-Schemas","type":"section","title":"Migrating Schemas","kind":"section"},"doc://VeinCore/tutorials/VeinCore/Quick-start-Xcode#Setup":{"title":"Setup","abstract":[{"text":"Install VeinCore and create your first model.","type":"text"}],"url":"\/tutorials\/veincore\/quick-start-xcode#Setup","kind":"section","type":"section","role":"pseudoSymbol","identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Quick-start-Xcode#Setup"},"doc://VeinCore/tutorials/VeinCore/CustomPersistable":{"url":"\/tutorials\/veincore\/custompersistable","type":"topic","identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/CustomPersistable","role":"project","abstract":[{"type":"text","text":"Make your own types persistable."}],"estimatedTime":"5min","title":"Custom Persistable","kind":"project"},"complex-migration-schemas.swift":{"highlights":[],"content":["import VeinCore","","\/\/ Our baseline schema","enum V0_0_1: VersionedSchema {","    static let version = ModelVersion(0, 0, 1)","    static let models: [any PersistentModel.Type] = [","        Test.self","    ]","","    @Model","    final class Test {","        var flag: Bool","        var someValue: String","        var randomValue: Int","","        init(flag: Bool, someValue: String, randomValue: Int) {","            self.flag = flag","            self.someValue = someValue","            self.randomValue = randomValue","        }","    }","}","","\/\/ Our destination schema","enum V0_0_2: VersionedSchema {","    static let version = ModelVersion(0, 0, 2)","    static let models: [any PersistentModel.Type] = [Test.self]","","    @Model","    final class Test {","        var flag: Bool","        var someValue: String","        var securityCode: String \/\/ This replaces the old raw Int","","        init(flag: Bool, someValue: String, securityCode: String) {","            self.flag = flag","            self.someValue = someValue","            self.securityCode = securityCode","        }","    }","}"],"fileName":"Schemas.swift","fileType":"swift","type":"file","syntax":"swift","identifier":"complex-migration-schemas.swift"},"doc://VeinCore/tutorials/VeinCore/SimpleMigrations":{"estimatedTime":"5min","title":"Simple Database Migrations","url":"\/tutorials\/veincore\/simplemigrations","abstract":[{"type":"text","text":"Effortlessly & safely evolve your database schema using stage-by-stage migrations & Vein helper functions."}],"role":"project","kind":"project","identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/SimpleMigrations","type":"topic"},"doc://VeinCore/tutorials/Table-of-Contents/Complex-Migrations":{"kind":"article","title":"Complex Migrations","type":"topic","url":"\/tutorials\/table-of-contents\/complex-migrations","abstract":[],"identifier":"doc:\/\/VeinCore\/tutorials\/Table-of-Contents\/Complex-Migrations","role":"article"}}}