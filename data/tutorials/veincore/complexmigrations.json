mplemigrations#Migrating-Schemas","kind":"section","type":"section","abstract":[{"type":"text","text":"Effortlessly & safely evolve your database schema using stage-by-stage migrations & Vein helper functions."}],"role":"pseudoSymbol","identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/SimpleMigrations#Migrating-Schemas","title":"Migrating Schemas"},"doc://VeinCore/tutorials/VeinCore/Quick-start-Swift-Package#Create-your-first-Model":{"title":"Create your first Model","abstract":[{"type":"text","text":"Install VeinCore and create your first model."}],"type":"section","kind":"section","role":"pseudoSymbol","url":"\/tutorials\/veincore\/quick-start-swift-package#Create-your-first-Model","identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Quick-start-Swift-Package#Create-your-first-Model"},"doc://VeinCore/tutorials/VeinCore/Relationships":{"estimatedTime":"3min","kind":"project","title":"Relationships","role":"project","type":"topic","url":"\/tutorials\/veincore\/relationships","identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Relationships","abstract":[{"text":"Use relationships with VeinCore.","type":"text"}]},"doc://VeinCore/tutorials/VeinCore/Quick-start-Swift-Package":{"type":"topic","url":"\/tutorials\/veincore\/quick-start-swift-package","kind":"project","identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Quick-start-Swift-Package","role":"project","title":"Quick start Swift Package","abstract":[{"type":"text","text":"Install VeinCore and create your first model."}],"estimatedTime":"5min"},"doc://VeinCore/tutorials/VeinCore/Quick-start-Swift-Package#Setup":{"kind":"section","role":"pseudoSymbol","title":"Setup","abstract":[{"type":"text","text":"Install VeinCore and create your first model."}],"type":"section","url":"\/tutorials\/veincore\/quick-start-swift-package#Setup","identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Quick-start-Swift-Package#Setup"},"doc://VeinCore/tutorials/VeinCore/SimpleMigrations":{"url":"\/tutorials\/veincore\/simplemigrations","type":"topic","kind":"project","abstract":[{"text":"Effortlessly & safely evolve your database schema using stage-by-stage migrations & Vein helper functions.","type":"text"}],"estimatedTime":"5min","role":"project","identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/SimpleMigrations","title":"Simple Database Migrations"},"doc://VeinCore/tutorials/VeinCore/Relationships#Adding-a-relationship-to-our-model":{"title":"Adding a relationship to our model","kind":"section","identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Relationships#Adding-a-relationship-to-our-model","role":"pseudoSymbol","url":"\/tutorials\/veincore\/relationships#Adding-a-relationship-to-our-model","type":"section","abstract":[{"type":"text","text":"Use relationships with VeinCore."}]},"doc://VeinCore/tutorials/Table-of-Contents/Complex-Migrations":{"kind":"article","identifier":"doc:\/\/VeinCore\/tutorials\/Table-of-Contents\/Complex-Migrations","url":"\/tutorials\/table-of-contents\/complex-migrations","title":"Complex Migrations","type":"topic","role":"article","abstract":[]},"doc://VeinCore/tutorials/Table-of-Contents":{"role":"overview","identifier":"doc:\/\/VeinCore\/tutorials\/Table-of-Contents","type":"topic","abstract":[{"text":"Database for apps made easy.","type":"text"}],"url":"\/tutorials\/table-of-contents","title":"Meet Vein","kind":"overview"},"complex-migration-stages-2.swift":{"identifier":"complex-migration-stages-2.swift","syntax":"swift","content":["import VeinCore","","enum ComplexMigration: SchemaMigrationPlan {","    static var schemas: [any VersionedSchema.Type] {","        [V0_0_1.self, V0_0_2.self]","    }","    ","    static var stages: [MigrationStage] {","        [migrateV1toV2]","    }","    ","    static let migrateV1toV2 = MigrationStage.complex(","        fromVersion: V0_0_1.self,","        toVersion: V0_0_2.self,","        willMigrate: { context in","            \/\/ 1. Fetch current models from the V1 database setup","            let oldTests = try context.fetchAll(V0_0_1.Test.self)","            ","            \/\/ 2. Map old entries to new types individually","            for test in oldTests {","                let sanitizedValue = max(0, test.randomValue)","                ","                let newTest = V0_0_2.Test(","                    flag: test.flag,","                    someValue: test.someValue,","                    securityCode: \"SEC-\\(sanitizedValue)\"","                )","                ","                \/\/ Add the new instance and remove the old one.","                \/\/ If a migration has unhandled non-empty tables at the end it will fail.","                try context.insert(newTest)","                try context.delete(test)","            }","        },","        didMigrate: nil","    )","}"],"highlights":[],"type":"file","fileType":"swift","fileName":"Migration.swift"},"doc://VeinCore/tutorials/VeinCore/ComplexMigrations":{"kind":"project","type":"topic","identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/ComplexMigrations","url":"\/tutorials\/veincore\/complexmigrations","abstract":[{"type":"text","text":"Handle structural database transformations by fetching existing models and inserting new ones."}],"role":"project","title":"Complex Migrations","estimatedTime":"7min"},"doc://VeinCore/tutorials/VeinCore/ComplexMigrations#Writing-Custom-Migration-Logic":{"title":"Writing Custom Migration Logic","type":"section","identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/ComplexMigrations#Writing-Custom-Migration-Logic","abstract":[{"type":"text","text":"Handle structural database transformations by fetching existing models and inserting new ones."}],"kind":"section","url":"\/tutorials\/veincore\/complexmigrations#Writing-Custom-Migration-Logic","role":"pseudoSymbol"},"doc://VeinCore/tutorials/VeinCore/Quick-start-Xcode#ModelContainer--ManagedObjectContext":{"kind":"section","title":"ModelContainer & ManagedObjectContext","type":"section","abstract":[{"type":"text","text":"Install VeinCore and create your first model."}],"identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Quick-start-Xcode#ModelContainer--ManagedObjectContext","url":"\/tutorials\/veincore\/quick-start-xcode#ModelContainer--ManagedObjectContext","role":"pseudoSymbol"},"doc://VeinCore/tutorials/Table-of-Contents/Simple-Migrations":{"identifier":"doc:\/\/VeinCore\/tutorials\/Table-of-Contents\/Simple-Migrations","title":"Simple Migrations","url":"\/tutorials\/table-of-contents\/simple-migrations","type":"topic","kind":"article","role":"article","abstract":[]},"complex-migration-stages-1.swift":{"identifier":"complex-migration-stages-1.swift","syntax":"swift","content":["import VeinCore","","enum ComplexMigration: SchemaMigrationPlan {","    static var schemas: [any VersionedSchema.Type] {","        [V0_0_1.self, V0_0_2.self]","    }","    ","    static var stages: [MigrationStage] {","        [migrateV1toV2]","    }","    ","    static let migrateV1toV2 = MigrationStage.complex(","        fromVersion: V0_0_1.self,","        toVersion: V0_0_2.self,","        willMigrate: { context in","            \/\/ Custom mapping logic will go here","        },","        didMigrate: nil","    )","}"],"highlights":[],"type":"file","fileName":"Migration.swift","fileType":"swift"},"doc://VeinCore/tutorials/Table-of-Contents/Relationships":{"title":"Relationships","role":"article","type":"topic","abstract":[],"identifier":"doc:\/\/VeinCore\/tutorials\/Table-of-Contents\/Relationships","url":"\/tutorials\/table-of-contents\/relationships","kind":"article"},"complex-migration-schemas.swift":{"identifier":"complex-migration-schemas.swift","syntax":"swift","content":["import VeinCore","","\/\/ Our baseline schema","enum V0_0_1: VersionedSchema {","    static let version = ModelVersion(0, 0, 1)","    static let models: [any PersistentModel.Type] = [","        Test.self","    ]","    ","    @Model","    final class Test {","        var flag: Bool","        var someValue: String","        var randomValue: Int","        ","        init(flag: Bool, someValue: String, randomValue: Int) {","            self.flag = flag","            self.someValue = someValue","            self.randomValue = randomValue","        }","    }","}","","\/\/ Our destination schema","enum V0_0_2: VersionedSchema {","    static let version = ModelVersion(0, 0, 2)","    static let models: [any PersistentModel.Type] = [Test.self]","    ","    @Model","    final class Test {","        var flag: Bool","        var someValue: String","        var securityCode: String \/\/ This replaces the old raw Int","        ","        init(flag: Bool, someValue: String, securityCode: String) {","            self.flag = flag","            self.someValue = someValue","            self.securityCode = securityCode","        }","    }","}"],"highlights":[],"type":"file","fileType":"swift","fileName":"Schemas.swift"}}}