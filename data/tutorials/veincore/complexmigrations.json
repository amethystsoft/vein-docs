igrations"},"doc://VeinCore/tutorials/VeinCore/Quick-start-Swift-Package#Setup":{"title":"Setup","type":"section","role":"pseudoSymbol","abstract":[{"type":"text","text":"Install VeinCore and create your first model."}],"kind":"section","identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Quick-start-Swift-Package#Setup","url":"\/tutorials\/veincore\/quick-start-swift-package#Setup"},"complex-migration-stages-1.swift":{"identifier":"complex-migration-stages-1.swift","fileType":"swift","type":"file","fileName":"Migration.swift","highlights":[],"syntax":"swift","content":["import VeinCore","","enum ComplexMigration: SchemaMigrationPlan {","    static var schemas: [any VersionedSchema.Type] {","        [V0_0_1.self, V0_0_2.self]","    }","    ","    static var stages: [MigrationStage] {","        [migrateV1toV2]","    }","    ","    static let migrateV1toV2 = MigrationStage.complex(","        fromVersion: V0_0_1.self,","        toVersion: V0_0_2.self,","        willMigrate: { context in","            \/\/ Custom mapping logic will go here","        },","        didMigrate: nil","    )","}"]},"doc://VeinCore/tutorials/VeinCore/CustomPersistable#Manual-Persistable":{"url":"\/tutorials\/veincore\/custompersistable#Manual-Persistable","title":"Manual Persistable","identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/CustomPersistable#Manual-Persistable","kind":"section","abstract":[{"type":"text","text":"Make your own types persistable."}],"type":"section","role":"pseudoSymbol"}}}