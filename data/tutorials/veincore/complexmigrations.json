"abstract":[{"type":"text","text":"Effortlessly & safely evolve your database schema using stage-by-stage migrations & Vein helper functions."}],"url":"\/tutorials\/veincore\/simplemigrations#Migrating-Schemas","identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/SimpleMigrations#Migrating-Schemas","title":"Migrating Schemas","role":"pseudoSymbol"},"doc://VeinCore/tutorials/Table-of-Contents/Simple-Migrations":{"abstract":[],"role":"article","type":"topic","title":"Simple Migrations","kind":"article","identifier":"doc:\/\/VeinCore\/tutorials\/Table-of-Contents\/Simple-Migrations","url":"\/tutorials\/table-of-contents\/simple-migrations"},"doc://VeinCore/tutorials/Table-of-Contents":{"title":"Meet Vein","type":"topic","kind":"overview","role":"overview","identifier":"doc:\/\/VeinCore\/tutorials\/Table-of-Contents","url":"\/tutorials\/table-of-contents","abstract":[{"type":"text","text":"Database for apps made easy."}]},"doc://VeinCore/tutorials/VeinCore/Quick-start-Swift-Package#ModelContainer--ManagedObjectContext":{"role":"pseudoSymbol","abstract":[{"type":"text","text":"Install VeinCore and create your first model."}],"url":"\/tutorials\/veincore\/quick-start-swift-package#ModelContainer--ManagedObjectContext","title":"ModelContainer & ManagedObjectContext","type":"section","kind":"section","identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Quick-start-Swift-Package#ModelContainer--ManagedObjectContext"},"doc://VeinCore/tutorials/VeinCore/Quick-start-Xcode":{"type":"topic","abstract":[{"type":"text","text":"Install VeinCore and create your first model."}],"identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Quick-start-Xcode","kind":"project","role":"project","url":"\/tutorials\/veincore\/quick-start-xcode","title":"Quick start Xcode","estimatedTime":"5min"},"doc://VeinCore/tutorials/VeinCore/Quick-start-Swift-Package#Create-your-first-Model":{"role":"pseudoSymbol","type":"section","title":"Create your first Model","identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Quick-start-Swift-Package#Create-your-first-Model","kind":"section","url":"\/tutorials\/veincore\/quick-start-swift-package#Create-your-first-Model","abstract":[{"type":"text","text":"Install VeinCore and create your first model."}]},"doc://VeinCore/tutorials/VeinCore/Quick-start-Xcode#ModelContainer--ManagedObjectContext":{"identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Quick-start-Xcode#ModelContainer--ManagedObjectContext","kind":"section","role":"pseudoSymbol","abstract":[{"type":"text","text":"Install VeinCore and create your first model."}],"title":"ModelContainer & ManagedObjectContext","type":"section","url":"\/tutorials\/veincore\/quick-start-xcode#ModelContainer--ManagedObjectContext"},"doc://VeinCore/tutorials/VeinCore/SimpleMigrations":{"title":"Simple Database Migrations","abstract":[{"text":"Effortlessly & safely evolve your database schema using stage-by-stage migrations & Vein helper functions.","type":"text"}],"role":"project","identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/SimpleMigrations","kind":"project","type":"topic","url":"\/tutorials\/veincore\/simplemigrations","estimatedTime":"5min"},"complex-migration-stages-1.swift":{"content":["import VeinCore","","enum ComplexMigration: SchemaMigrationPlan {","    static var schemas: [any VersionedSchema.Type] {","        [V0_0_1.self, V0_0_2.self]","    }","    ","    static var stages: [MigrationStage] {","        [migrateV1toV2]","    }","    ","    static let migrateV1toV2 = MigrationStage.complex(","        fromVersion: V0_0_1.self,","        toVersion: V0_0_2.self,","        willMigrate: { context in","            \/\/ Custom mapping logic will go here","        },","        didMigrate: nil","    )","}"],"highlights":[],"type":"file","fileType":"swift","identifier":"complex-migration-stages-1.swift","fileName":"Migration.swift","syntax":"swift"},"doc://VeinCore/tutorials/VeinCore/Relationships#Persisting--fetching-a-relationship":{"title":"Persisting & fetching a relationship","abstract":[{"type":"text","text":"Use relationships with VeinCore."}],"identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Relationships#Persisting--fetching-a-relationship","url":"\/tutorials\/veincore\/relationships#Persisting--fetching-a-relationship","kind":"section","role":"pseudoSymbol","type":"section"},"doc://VeinCore/tutorials/VeinCore/ComplexMigrations#Writing-Custom-Migration-Logic":{"type":"section","kind":"section","abstract":[{"text":"Handle structural database transformations by fetching existing models and inserting new ones.","type":"text"}],"title":"Writing Custom Migration Logic","role":"pseudoSymbol","identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/ComplexMigrations#Writing-Custom-Migration-Logic","url":"\/tutorials\/veincore\/complexmigrations#Writing-Custom-Migration-Logic"},"doc://VeinCore/tutorials/VeinCore/Quick-start-Swift-Package":{"estimatedTime":"5min","identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Quick-start-Swift-Package","kind":"project","url":"\/tutorials\/veincore\/quick-start-swift-package","role":"project","type":"topic","abstract":[{"text":"Install VeinCore and create your first model.","type":"text"}],"title":"Quick start Swift Package"},"doc://VeinCore/tutorials/VeinCore/ComplexMigrations":{"estimatedTime":"7min","title":"Complex Migrations","type":"topic","kind":"project","abstract":[{"text":"Handle structural database transformations by fetching existing models and inserting new ones.","type":"text"}],"identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/ComplexMigrations","url":"\/tutorials\/veincore\/complexmigrations","role":"project"},"complex-migration-schemas.swift":{"identifier":"complex-migration-schemas.swift","fileType":"swift","fileName":"Schemas.swift","highlights":[],"type":"file","syntax":"swift","content":["import VeinCore","","\/\/ Our baseline schema","enum V0_0_1: VersionedSchema {","    static let version = ModelVersion(0, 0, 1)","    static let models: [any PersistentModel.Type] = [","        Test.self","    ]","    ","    @Model","    final class Test {","        var flag: Bool","        var someValue: String","        var randomValue: Int","        ","        init(flag: Bool, someValue: String, randomValue: Int) {","            self.flag = flag","            self.someValue = someValue","            self.randomValue = randomValue","        }","    }","}","","\/\/ Our destination schema","enum V0_0_2: VersionedSchema {","    static let version = ModelVersion(0, 0, 2)","    static let models: [any PersistentModel.Type] = [Test.self]","    ","    @Model","    final class Test {","        var flag: Bool","        var someValue: String","        var securityCode: String \/\/ This replaces the old raw Int","        ","        init(flag: Bool, someValue: String, securityCode: String) {","            self.flag = flag","            self.someValue = someValue","            self.securityCode = securityCode","        }","    }","}"]},"doc://VeinCore/tutorials/VeinCore/Quick-start-Xcode#Create-your-first-Model":{"kind":"section","identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Quick-start-Xcode#Create-your-first-Model","type":"section","url":"\/tutorials\/veincore\/quick-start-xcode#Create-your-first-Model","abstract":[{"text":"Install VeinCore and create your first model.","type":"text"}],"role":"pseudoSymbol","title":"Create your first Model"},"doc://VeinCore/tutorials/VeinCore/Relationships":{"title":"Relationships","abstract":[{"type":"text","text":"Use relationships with VeinCore."}],"role":"project","identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Relationships","kind":"project","type":"topic","url":"\/tutorials\/veincore\/relationships","estimatedTime":"3min"},"doc://VeinCore/tutorials/VeinCore/Relationships#Adding-a-relationship-to-our-model":{"identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Relationships#Adding-a-relationship-to-our-model","kind":"section","abstract":[{"type":"text","text":"Use relationships with VeinCore."}],"role":"pseudoSymbol","url":"\/tutorials\/veincore\/relationships#Adding-a-relationship-to-our-model","type":"section","title":"Adding a relationship to our model"},"doc://VeinCore/tutorials/Table-of-Contents/Quick-start":{"identifier":"doc:\/\/VeinCore\/tutorials\/Table-of-Contents\/Quick-start","kind":"article","role":"article","title":"Quick start","url":"\/tutorials\/table-of-contents\/quick-start","type":"topic","abstract":[]},"complex-migration-stages-2.swift":{"fileName":"Migration.swift","fileType":"swift","identifier":"complex-migration-stages-2.swift","content":["import VeinCore","","enum ComplexMigration: SchemaMigrationPlan {","    static var schemas: [any VersionedSchema.Type] {","        [V0_0_1.self, V0_0_2.self]","    }","    ","    static var stages: [MigrationStage] {","        [migrateV1toV2]","    }","    ","    static let migrateV1toV2 = MigrationStage.complex(","        fromVersion: V0_0_1.self,","        toVersion: V0_0_2.self,","        willMigrate: { context in","            \/\/ 1. Fetch current models from the V1 database setup","            let oldTests = try context.fetchAll(V0_0_1.Test.self)","            ","            \/\/ 2. Map old entries to new types individually","            for test in oldTests {","                let sanitizedValue = max(0, test.randomValue)","                ","                let newTest = V0_0_2.Test(","                    flag: test.flag,","                    someValue: test.someValue,","                    securityCode: \"SEC-\\(sanitizedValue)\"","                )","                ","                \/\/ Add the new instance and remove the old one.","                \/\/ If a migration has unhandled non-empty tables at the end it will fail.","                try context.insert(newTest)","                try context.delete(test)","            }","        },","        didMigrate: nil","    )","}"],"highlights":[],"syntax":"swift","type":"file"},"doc://VeinCore/tutorials/VeinCore/Quick-start-Swift-Package#Setup":{"abstract":[{"text":"Install VeinCore and create your first model.","type":"text"}],"identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Quick-start-Swift-Package#Setup","title":"Setup","type":"section","kind":"section","url":"\/tutorials\/veincore\/quick-start-swift-package#Setup","role":"pseudoSymbol"},"doc://VeinCore/tutorials/Table-of-Contents/Relationships":{"url":"\/tutorials\/table-of-contents\/relationships","identifier":"doc:\/\/VeinCore\/tutorials\/Table-of-Contents\/Relationships","title":"Relationships","abstract":[],"type":"topic","role":"article","kind":"article"},"doc://VeinCore/tutorials/Table-of-Contents/Complex-Migrations":{"abstract":[],"title":"Complex Migrations","url":"\/tutorials\/table-of-contents\/complex-migrations","identifier":"doc:\/\/VeinCore\/tutorials\/Table-of-Contents\/Complex-Migrations","role":"article","type":"topic","kind":"article"}}}