\/tutorials\/VeinCore\/ComplexMigrations#Writing-Custom-Migration-Logic","kind":"task"}]}],"reference":"doc:\/\/VeinCore\/tutorials\/Table-of-Contents\/Complex-Migrations"},{"projects":[{"reference":"doc:\/\/VeinCore\/tutorials\/VeinCore\/CustomPersistable","sections":[{"reference":"doc:\/\/VeinCore\/tutorials\/VeinCore\/CustomPersistable#RawRepresentable","kind":"task"},{"reference":"doc:\/\/VeinCore\/tutorials\/VeinCore\/CustomPersistable#Codable","kind":"task"},{"reference":"doc:\/\/VeinCore\/tutorials\/VeinCore\/CustomPersistable#Manual-Persistable","kind":"task"}]}],"reference":"doc:\/\/VeinCore\/tutorials\/Table-of-Contents\/Custom-Persistable"}],"reference":"doc:\/\/VeinCore\/tutorials\/Table-of-Contents"},"metadata":{"categoryPathComponent":"Table-of-Contents","role":"project","title":"Complex Migrations","category":"Vein"},"schemaVersion":{"minor":3,"patch":0,"major":0},"sections":[{"title":"Complex Migrations","estimatedTimeInMinutes":7,"kind":"hero","content":[{"inlineContent":[{"type":"text","text":"Handle structural database transformations by fetching existing models and inserting new ones."}],"type":"paragraph"}],"chapter":"Complex Migrations"},{"tasks":[{"anchor":"Writing-Custom-Migration-Logic","stepsSection":[{"code":"complex-migration-schemas.swift","runtimePreview":null,"media":null,"content":[{"inlineContent":[{"type":"text","text":"Define the baseline and destination schemas. Notice that "},{"code":"V0_0_2.Test","type":"codeVoice"},{"type":"text","text":" now requires a non-optional "},{"code":"securityCode","type":"codeVoice"},{"type":"text","text":" instead of "},{"code":"randomValue","type":"codeVoice"},{"type":"text","text":", meaning simple column additions won’t work."}],"type":"paragraph"}],"type":"step","caption":[]},{"media":null,"code":"complex-migration-stages-1.swift","type":"step","caption":[],"runtimePreview":null,"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Set up your "},{"code":"SchemaMigrationPlan","type":"codeVoice"},{"type":"text","text":" block, preparing a "},{"code":".complex","type":"codeVoice"},{"type":"text","text":" transition stage from version 1 to version 2."}]}]},{"media":null,"code":"complex-migration-stages-2.swift","type":"step","caption":[],"runtimePreview":null,"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Implement the migration logic. Fetch the baseline records, execute your custom business rules, and save the mapped models back to the new schema inside the transition step."}]}]}],"title":"Writing Custom Migration Logic","contentSection":[{"kind":"contentAndMedia","mediaPosition":"trailing","content":[{"inlineContent":[{"text":"Simple migration helpers are great for adding fields or dropping tables. However, when you rename fields, merge schemas, or modify non-optional data types (like mapping an ","type":"text"},{"code":"Int","type":"codeVoice"},{"type":"text","text":" to a formatted "},{"type":"codeVoice","code":"String"},{"type":"text","text":"), you need a custom migration."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"In this tutorial, we will migrate from "},{"type":"codeVoice","code":"V0_0_1"},{"type":"text","text":" to "},{"type":"codeVoice","code":"V0_0_2"},{"type":"text","text":" where we:"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"text":"Map an old model’s field ","type":"text"},{"code":"randomValue","type":"codeVoice"},{"text":" (Int) into a formatted ","type":"text"},{"code":"securityCode","type":"codeVoice"},{"text":" (String).","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Apply processing rules during the transfer (clamping negative numbers to zero).","type":"text"}],"type":"paragraph"}]}]}]}]}],"kind":"tasks"},{"abstract":[{"type":"text","text":"Make your own types persistable."}],"kind":"callToAction","title":"Custom Persistable","action":{"overridingTitle":"Get started","isActive":true,"identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/CustomPersistable","overridingTitleInlineContent":[{"type":"text","text":"Get started"}],"type":"reference"},"featuredEyebrow":"Tutorial"}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/VeinCore\/tutorials\/VeinCore\/ComplexMigrations"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/tutorials\/veincore\/complexmigrations"]}],"references":{"doc://VeinCore/tutorials/Table-of-Contents/Custom-Persistable":{"title":"Custom Persistable","kind":"article","role":"article","url":"\/tutorials\/table-of-contents\/custom-persistable","abstract":[],"identifier":"doc:\/\/VeinCore\/tutorials\/Table-of-Contents\/Custom-Persistable","type":"topic"},"doc://VeinCore/tutorials/VeinCore/Quick-start-Xcode#ModelContainer--ManagedObjectContext":{"role":"pseudoSymbol","type":"section","identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Quick-start-Xcode#ModelContainer--ManagedObjectContext","title":"ModelContainer & ManagedObjectContext","abstract":[{"text":"Install VeinCore and create your first model.","type":"text"}],"url":"\/tutorials\/veincore\/quick-start-xcode#ModelContainer--ManagedObjectContext","kind":"section"},"doc://VeinCore/tutorials/VeinCore/Relationships#Adding-a-relationship-to-our-model":{"role":"pseudoSymbol","type":"section","identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Relationships#Adding-a-relationship-to-our-model","title":"Adding a relationship to our model","abstract":[{"text":"Use relationships with VeinCore.","type":"text"}],"url":"\/tutorials\/veincore\/relationships#Adding-a-relationship-to-our-model","kind":"section"},"doc://VeinCore/tutorials/VeinCore/Relationships":{"abstract":[{"text":"Use relationships with VeinCore.","type":"text"}],"role":"project","kind":"project","type":"topic","url":"\/tutorials\/veincore\/relationships","title":"Relationships","estimatedTime":"3min","identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Relationships"},"doc://VeinCore/tutorials/VeinCore/ComplexMigrations":{"url":"\/tutorials\/veincore\/complexmigrations","type":"topic","kind":"project","role":"project","identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/ComplexMigrations","estimatedTime":"7min","abstract":[{"text":"Handle structural database transformations by fetching existing models and inserting new ones.","type":"text"}],"title":"Complex Migrations"},"doc://VeinCore/tutorials/Table-of-Contents":{"title":"Meet Vein","url":"\/tutorials\/table-of-contents","identifier":"doc:\/\/VeinCore\/tutorials\/Table-of-Contents","role":"overview","type":"topic","abstract":[{"type":"text","text":"Database for apps made easy."}],"kind":"overview"},"doc://VeinCore/tutorials/VeinCore/Quick-start-Swift-Package#ModelContainer--ManagedObjectContext":{"abstract":[{"text":"Install VeinCore and create your first model.","type":"text"}],"url":"\/tutorials\/veincore\/quick-start-swift-package#ModelContainer--ManagedObjectContext","identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Quick-start-Swift-Package#ModelContainer--ManagedObjectContext","role":"pseudoSymbol","type":"section","kind":"section","title":"ModelContainer & ManagedObjectContext"},"complex-migration-schemas.swift":{"content":["import VeinCore","","\/\/ Our baseline schema","enum V0_0_1: VersionedSchema {","    static let version = ModelVersion(0, 0, 1)","    static let models: [any PersistentModel.Type] = [","        Test.self","    ]","    ","    @Model","    final class Test {","        var flag: Bool","        var someValue: String","        var randomValue: Int","        ","        init(flag: Bool, someValue: String, randomValue: Int) {","            self.flag = flag","            self.someValue = someValue","            self.randomValue = randomValue","        }","    }","}","","\/\/ Our destination schema","enum V0_0_2: VersionedSchema {","    static let version = ModelVersion(0, 0, 2)","    static let models: [any PersistentModel.Type] = [Test.self]","    ","    @Model","    final class Test {","        var flag: Bool","        var someValue: String","        var securityCode: String \/\/ This replaces the old raw Int","        ","        init(flag: Bool, someValue: String, securityCode: String) {","            self.flag = flag","            self.someValue = someValue","            self.securityCode = securityCode","        }","    }","}"],"fileName":"Schemas.swift","fileType":"swift","identifier":"complex-migration-schemas.swift","syntax":"swift","highlights":[],"type":"file"},"doc://VeinCore/tutorials/Table-of-Contents/Quick-start":{"role":"article","title":"Quick start","identifier":"doc:\/\/VeinCore\/tutorials\/Table-of-Contents\/Quick-start","type":"topic","kind":"article","abstract":[],"url":"\/tutorials\/table-of-contents\/quick-start"},"doc://VeinCore/tutorials/VeinCore/Quick-start-Swift-Package":{"abstract":[{"type":"text","text":"Install VeinCore and create your first model."}],"type":"topic","role":"project","identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Quick-start-Swift-Package","estimatedTime":"5min","title":"Quick start Swift Package","url":"\/tutorials\/veincore\/quick-start-swift-package","kind":"project"},"doc://VeinCore/tutorials/Table-of-Contents/Complex-Migrations":{"kind":"article","role":"article","type":"topic","url":"\/tutorials\/table-of-contents\/complex-migrations","abstract":[],"identifier":"doc:\/\/VeinCore\/tutorials\/Table-of-Contents\/Complex-Migrations","title":"Complex Migrations"},"doc://VeinCore/tutorials/VeinCore/ComplexMigrations#Writing-Custom-Migration-Logic":{"identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/ComplexMigrations#Writing-Custom-Migration-Logic","url":"\/tutorials\/veincore\/complexmigrations#Writing-Custom-Migration-Logic","role":"pseudoSymbol","title":"Writing Custom Migration Logic","kind":"section","abstract":[{"type":"text","text":"Handle structural database transformations by fetching existing models and inserting new ones."}],"type":"section"},"doc://VeinCore/tutorials/VeinCore/CustomPersistable":{"role":"project","title":"Custom Persistable","type":"topic","kind":"project","url":"\/tutorials\/veincore\/custompersistable","estimatedTime":"5min","abstract":[{"type":"text","text":"Make your own types persistable."}],"identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/CustomPersistable"},"complex-migration-stages-2.swift":{"fileType":"swift","fileName":"Migration.swift","content":["import VeinCore","","enum ComplexMigration: SchemaMigrationPlan {","    static var schemas: [any VersionedSchema.Type] {","        [V0_0_1.self, V0_0_2.self]","    }","    ","    static var stages: [MigrationStage] {","        [migrateV1toV2]","    }","    ","    static let migrateV1toV2 = MigrationStage.complex(","        fromVersion: V0_0_1.self,","        toVersion: V0_0_2.self,","        willMigrate: { context in","            \/\/ 1. Fetch current models from the V1 database setup","            let oldTests = try context.fetchAll(V0_0_1.Test.self)","            ","            \/\/ 2. Map old entries to new types individually","            for test in oldTests {","                let sanitizedValue = max(0, test.randomValue)","                ","                let newTest = V0_0_2.Test(","                    flag: test.flag,","                    someValue: test.someValue,","                    securityCode: \"SEC-\\(sanitizedValue)\"","                )","                ","                \/\/ Add the new instance and remove the old one.","                \/\/ If a migration has unhandled non-empty tables at the end it will fail.","                try context.insert(newTest)","                try context.delete(test)","            }","        },","        didMigrate: nil","    )","}"],"type":"file","syntax":"swift","identifier":"complex-migration-stages-2.swift","highlights":[]},"doc://VeinCore/tutorials/VeinCore/CustomPersistable#Codable":{"title":"Codable","identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/CustomPersistable#Codable","kind":"section","abstract":[{"type":"text","text":"Make your own types persistable."}],"url":"\/tutorials\/veincore\/custompersistable#Codable","type":"section","role":"pseudoSymbol"},"doc://VeinCore/tutorials/VeinCore/Relationships#Persisting--fetching-a-relationship":{"kind":"section","type":"section","url":"\/tutorials\/veincore\/relationships#Persisting--fetching-a-relationship","identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Relationships#Persisting--fetching-a-relationship","abstract":[{"type":"text","text":"Use relationships with VeinCore."}],"role":"pseudoSymbol","title":"Persisting & fetching a relationship"},"doc://VeinCore/tutorials/Table-of-Contents/Simple-Migrations":{"kind":"article","type":"topic","role":"article","url":"\/tutorials\/table-of-contents\/simple-migrations","title":"Simple Migrations","abstract":[],"identifier":"doc:\/\/VeinCore\/tutorials\/Table-of-Contents\/Simple-Migrations"},"doc://VeinCore/tutorials/VeinCore/Quick-start-Xcode#Create-your-first-Model":{"abstract":[{"type":"text","text":"Install VeinCore and create your first model."}],"role":"pseudoSymbol","identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Quick-start-Xcode#Create-your-first-Model","url":"\/tutorials\/veincore\/quick-start-xcode#Create-your-first-Model","kind":"section","title":"Create your first Model","type":"section"},"doc://VeinCore/tutorials/VeinCore/CustomPersistable#RawRepresentable":{"role":"pseudoSymbol","identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/CustomPersistable#RawRepresentable","url":"\/tutorials\/veincore\/custompersistable#RawRepresentable","type":"section","title":"RawRepresentable","kind":"section","abstract":[{"text":"Make your own types persistable.","type":"text"}]},"doc://VeinCore/tutorials/VeinCore/Quick-start-Xcode":{"identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Quick-start-Xcode","title":"Quick start Xcode","kind":"project","type":"topic","url":"\/tutorials\/veincore\/quick-start-xcode","role":"project","estimatedTime":"5min","abstract":[{"text":"Install VeinCo