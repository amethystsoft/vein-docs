{"schemaVersion":{"minor":3,"major":0,"patch":0},"variants":[{"paths":["\/tutorials\/veincore\/complexmigrations"],"traits":[{"interfaceLanguage":"swift"}]}],"metadata":{"categoryPathComponent":"Table-of-Contents","title":"Complex Migrations","role":"project","category":"Vein"},"kind":"project","sections":[{"kind":"hero","chapter":"Complex Migrations","title":"Complex Migrations","content":[{"type":"paragraph","inlineContent":[{"text":"Handle structural database transformations by fetching existing models and inserting new ones.","type":"text"}]}],"estimatedTimeInMinutes":7},{"tasks":[{"title":"Writing Custom Migration Logic","anchor":"Writing-Custom-Migration-Logic","contentSection":[{"mediaPosition":"trailing","kind":"contentAndMedia","content":[{"inlineContent":[{"type":"text","text":"Simple migration helpers are great for adding fields or dropping tables. However, when you rename fields, merge schemas, or modify non-optional data types (like mapping an "},{"code":"Int","type":"codeVoice"},{"type":"text","text":" to a formatted "},{"code":"String","type":"codeVoice"},{"type":"text","text":"), you need a custom migration."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"In this tutorial, we will migrate from ","type":"text"},{"type":"codeVoice","code":"V0_0_1"},{"text":" to ","type":"text"},{"type":"codeVoice","code":"V0_0_2"},{"text":" where we:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Map an old model’s field ","type":"text"},{"type":"codeVoice","code":"randomValue"},{"text":" (Int) into a formatted ","type":"text"},{"type":"codeVoice","code":"securityCode"},{"text":" (String).","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Apply processing rules during the transfer (clamping negative numbers to zero)."}],"type":"paragraph"}]}]}]}],"stepsSection":[{"content":[{"inlineContent":[{"type":"text","text":"Define the baseline and destination schemas. Notice that "},{"type":"codeVoice","code":"V0_0_2.Test"},{"type":"text","text":" now requires a non-optional "},{"type":"codeVoice","code":"securityCode"},{"type":"text","text":" instead of "},{"type":"codeVoice","code":"randomValue"},{"type":"text","text":", meaning simple column additions won’t work."}],"type":"paragraph"}],"media":null,"runtimePreview":null,"code":"complex-migration-schemas.swift","type":"step","caption":[]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Set up your "},{"type":"codeVoice","code":"SchemaMigrationPlan"},{"type":"text","text":" block, preparing a "},{"type":"codeVoice","code":".complex"},{"type":"text","text":" transition stage from version 1 to version 2."}]}],"media":null,"runtimePreview":null,"code":"complex-migration-stages-1.swift","type":"step","caption":[]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Implement the migration logic. Fetch the baseline records, execute your custom business rules, and save the mapped models back to the new schema inside the transition step.","type":"text"}]}],"media":null,"runtimePreview":null,"code":"complex-migration-stages-2.swift","type":"step","caption":[]}]}],"kind":"tasks"}],"identifier":{"url":"doc:\/\/VeinCore\/tutorials\/VeinCore\/ComplexMigrations","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc:\/\/VeinCore\/tutorials\/Table-of-Contents","doc:\/\/VeinCore\/tutorials\/Table-of-Contents\/$volume","doc:\/\/VeinCore\/tutorials\/Table-of-Contents\/Complex-Migrations"]],"modules":[{"reference":"doc:\/\/VeinCore\/tutorials\/Table-of-Contents\/Quick-start","projects":[{"sections":[{"reference":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Quick-start-Swift-Package#Setup","kind":"task"},{"reference":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Quick-start-Swift-Package#Create-your-first-Model","kind":"task"},{"reference":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Quick-start-Swift-Package#ModelContainer--ManagedObjectContext","kind":"task"}],"reference":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Quick-start-Swift-Package"},{"reference":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Quick-start-Xcode","sections":[{"kind":"task","reference":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Quick-start-Xcode#Setup"},{"kind":"task","reference":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Quick-start-Xcode#Create-your-first-Model"},{"kind":"task","reference":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Quick-start-Xcode#ModelContainer--ManagedObjectContext"}]}]},{"projects":[{"reference":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Relationships","sections":[{"reference":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Relationships#Adding-a-relationship-to-our-model","kind":"task"},{"reference":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Relationships#Persisting--fetching-a-relationship","kind":"task"}]}],"reference":"doc:\/\/VeinCore\/tutorials\/Table-of-Contents\/Relationships"},{"projects":[{"reference":"doc:\/\/VeinCore\/tutorials\/VeinCore\/SimpleMigrations","sections":[{"kind":"task","reference":"doc:\/\/VeinCore\/tutorials\/VeinCore\/SimpleMigrations#Migrating-Schemas"}]}],"reference":"doc:\/\/VeinCore\/tutorials\/Table-of-Contents\/Simple-Migrations"},{"projects":[{"sections":[{"reference":"doc:\/\/VeinCore\/tutorials\/VeinCore\/ComplexMigrations#Writing-Custom-Migration-Logic","kind":"task"}],"reference":"doc:\/\/VeinCore\/tutorials\/VeinCore\/ComplexMigrations"}],"reference":"doc:\/\/VeinCore\/tutorials\/Table-of-Contents\/Complex-Migrations"}],"reference":"doc:\/\/VeinCore\/tutorials\/Table-of-Contents"},"references":{"doc://VeinCore/tutorials/VeinCore/Quick-start-Xcode":{"title":"Quick start Xcode","url":"\/tutorials\/veincore\/quick-start-xcode","type":"topic","estimatedTime":"5min","identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Quick-start-Xcode","kind":"project","abstract":[{"type":"text","text":"Install VeinCore and create your first model."}],"role":"project"},"doc://VeinCore/tutorials/Table-of-Contents/Quick-start":{"title":"Quick start","kind":"article","role":"article","url":"\/tutorials\/table-of-contents\/quick-start","type":"topic","abstract":[],"identifier":"doc:\/\/VeinCore\/tutorials\/Table-of-Contents\/Quick-start"},"complex-migration-stages-2.swift":{"identifier":"complex-migration-stages-2.swift","fileType":"swift","content":["import VeinCore","","enum ComplexMigration: SchemaMigrationPlan {","    static var schemas: [any VersionedSchema.Type] {","        [V0_0_1.self, V0_0_2.self]","    }","    ","    static var stages: [MigrationStage] {","        [migrateV1toV2]","    }","    ","    static let migrateV1toV2 = MigrationStage.complex(","        fromVersion: V0_0_1.self,","        toVersion: V0_0_2.self,","        willMigrate: { context in","            \/\/ 1. Fetch current models from the V1 database setup","            let oldTests = try context.fetchAll(V0_0_1.Test.self)","            ","            \/\/ 2. Map old entries to new types individually","            for test in oldTests {","                let sanitizedValue = max(0, test.randomValue)","                ","                let newTest = V0_0_2.Test(","                    flag: test.flag,","                    someValue: test.someValue,","                    securityCode: \"SEC-\\(sanitizedValue)\"","                )","                ","                \/\/ Add the new instance and remove the old one.","                \/\/ If a migration has unhandled non-empty tables at the end it will fail.","                try context.insert(newTest)","                try context.delete(test)","            }","        },","        didMigrate: nil","    )","}"],"fileName":"Migration.swift","highlights":[],"type":"file","syntax":"swift"},"doc://VeinCore/tutorials/Table-of-Contents/Complex-Migrations":{"type":"topic","title":"Complex Migrations","url":"\/tutorials\/table-of-contents\/complex-migrations","role":"article","abstract":[],"identifier":"doc:\/\/VeinCore\/tutorials\/Table-of-Contents\/Complex-Migrations","kind":"article"},"doc://VeinCore/tutorials/VeinCore/Relationships#Adding-a-relationship-to-our-model":{"abstract":[{"text":"Use relationships with VeinCore.","type":"text"}],"type":"section","identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Relationships#Adding-a-relationship-to-our-model","role":"pseudoSymbol","url":"\/tutorials\/veincore\/relationships#Adding-a-relationship-to-our-model","title":"Adding a relationship to our model","kind":"section"},"doc://VeinCore/tutorials/VeinCore/Quick-start-Swift-Package#Setup":{"type":"section","role":"pseudoSymbol","title":"Setup","identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Quick-start-Swift-Package#Setup","url":"\/tutorials\/veincore\/quick-start-swift-package#Setup","kind":"section","abstract":[{"type":"text","text":"Install VeinCore and create your first model."}]},"doc://VeinCore/tutorials/Table-of-Contents/Simple-Migrations":{"identifier":"doc:\/\/VeinCore\/tutorials\/Table-of-Contents\/Simple-Migrations","title":"Simple Migrations","role":"article","url":"\/tutorials\/table-of-contents\/simple-migrations","kind":"article","abstract":[],"type":"topic"},"doc://VeinCore/tutorials/Table-of-Contents/Relationships":{"role":"article","identifier":"doc:\/\/VeinCore\/tutorials\/Table-of-Contents\/Relationships","type":"topic","abstract":[],"title":"Relationships","kind":"article","url":"\/tutorials\/table-of-contents\/relationships"},"doc://VeinCore/tutorials/VeinCore/SimpleMigrations#Migrating-Schemas":{"title":"Migrating Schemas","identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/SimpleMigrations#Migrating-Schemas","kind":"section","url":"\/tutorials\/veincore\/simplemigrations#Migrating-Schemas","abstract":[{"type":"text","text":"Effortlessly & safely evolve your database schema using stage-by-stage migrations & Vein helper functions."}],"role":"pseudoSymbol","type":"section"},"doc://VeinCore/tutorials/VeinCore/ComplexMigrations#Writing-Custom-Migration-Logic":{"kind":"section","title":"Writing Custom Migration Logic","url":"\/tutorials\/veincore\/complexmigrations#Writing-Custom-Migration-Logic","identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/ComplexMigrations#Writing-Custom-Migration-Logic","abstract":[{"text":"Handle structural database transformations by fetching existing models and inserting new ones.","type":"text"}],"role":"pseudoSymbol","type":"section"},"doc://VeinCore/tutorials/VeinCore/Quick-start-Swift-Package#ModelContainer--ManagedObjectContext":{"title":"ModelContainer & ManagedObjectContext","type":"section","identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Quick-start-Swift-Package#ModelContainer--ManagedObjectContext","kind":"section","url":"\/tutorials\/veincore\/quick-start-swift-package#ModelContainer--ManagedObjectContext","abstract":[{"text":"Install VeinCore and create your first model.","type":"text"}],"role":"pseudoSymbol"},"doc://VeinCore/tutorials/VeinCore/Quick-start-Xcode#Setup":{"title":"Setup","type":"section","identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Quick-start-Xcode#Setup","kind":"section","url":"\/tutorials\/veincore\/quick-start-xcode#Setup","abstract":[{"type":"text","text":"Install VeinCore and create your first model."}],"role":"pseudoSymbol"},"doc://VeinCore/tutorials/VeinCore/Relationships":{"role":"project","kind":"project","estimatedTime":"3min","abstract":[{"text":"Use relationships with VeinCore.","type":"text"}],"identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Relationships","type":"topic","url":"\/tutorials\/veincore\/relationships","title":"Relationships"},"doc://VeinCore/tutorials/VeinCore/Quick-start-Swift-Package":{"type":"topic","title":"Quick start Swift Package","kind":"project","url":"\/tutorials\/veincore\/quick-start-swift-package","abstract":[{"text":"Install VeinCore and create your first model.","type":"text"}],"estimatedTime":"5min","identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Quick-start-Swift-Package","role":"project"},"doc://VeinCore/tutorials/Table-of-Contents":{"role":"overview","kind":"overview","abstract":[{"type":"text","text":"Database for apps made easy."}],"identifier":"doc:\/\/VeinCore\/tutorials\/Table-of-Contents","type":"topic","url":"\/tutorials\/table-of-contents","title":"Meet Vein"},"doc://VeinCore/tutorials/VeinCore/SimpleMigrations":{"abstract":[{"text":"Effortlessly & safely evolve your database schema using stage-by-stage migrations & Vein helper functions.","type":"text"}],"identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/SimpleMigrations","url":"\/tutorials\/veincore\/simplemigrations","title":"Simple Database Migrations","role":"project","type":"topic","estimatedTime":"5min","kind":"project"},"doc://VeinCore/tutorials/VeinCore/Quick-start-Xcode#Create-your-first-Model":{"role":"pseudoSymbol","identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Quick-start-Xcode#Create-your-first-Model","kind":"section","title":"Create your first Model","type":"section","abstract":[{"text":"Install VeinCore and create your first model.","type":"text"}],"url":"\/tutorials\/veincore\/quick-start-xcode#Create-your-first-Model"},"complex-migration-schemas.swift":{"fileType":"swift","type":"file","syntax":"swift","fileName":"Schemas.swift","highlights":[],"content":["import VeinCore","","\/\/ Our baseline schema","enum V0_0_1: VersionedSchema {","    static let version = ModelVersion(0, 0, 1)","    static let models: [any PersistentModel.Type] = [","        Test.self","    ]","    ","    @Model","    final class Test {","        var flag: Bool","        var someValue: String","        var randomValue: Int","        ","        init(flag: Bool, someValue: String, randomValue: Int) {","            self.flag = flag","            self.someValue = someValue","            self.randomValue = randomValue","        }","    }","}","","\/\/ Our destination schema","enum V0_0_2: VersionedSchema {","    static let version = ModelVersion(0, 0, 2)","    static let models: [any PersistentModel.Type] = [Test.self]","    ","    @Model","    final class Test {","        var flag: Bool","        var someValue: String","        var securityCode: String \/\/ This replaces the old raw Int","        ","        init(flag: Bool, someValue: String, securityCode: String) {","            self.flag = flag","            self.someValue = someValue","            self.securityCode = securityCode","        }","    }","}"],"identifier":"complex-migration-schemas.swift"},"complex-migration-stages-1.swift":{"identifier":"complex-migration-stages-1.swift","content":["import VeinCore","","enum ComplexMigration: SchemaMigrationPlan {","    static var schemas: [any VersionedSchema.Type] {","        [V0_0_1.self, V0_0_2.self]","    }","    ","    static var stages: [MigrationStage] {","        [migrateV1toV2]","    }","    ","    static let migrateV1toV2 = MigrationStage.complex(","        fromVersion: V0_0_1.self,","        toVersion: V0_0_2.self,","        willMigrate: { context in","            \/\/ Custom mapping logic will go here","        },","        didMigrate: nil","    )","}"],"fileName":"Migration.swift","syntax":"swift","fileType":"swift","type":"file","highlights":[]},"doc://VeinCore/tutorials/VeinCore/Relationships#Persisting--fetching-a-relationship":{"role":"pseudoSymbol","identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Relationships#Persisting--fetching-a-relationship","kind":"section","type":"section","abstract":[{"type":"text","text":"Use relationships with VeinCore."}],"title":"Persisting & fetching a relationship","url":"\/tutorials\/veincore\/relationships#Persisting--fetching-a-relationship"},"doc://VeinCore/tutorials/VeinCore/ComplexMigrations":{"estimatedTime":"7min","role":"project","kind":"project","url":"\/tutorials\/veincore\/complexmigrations","type":"topic","title":"Complex Migrations","abstract":[{"type":"text","text":"Handle structural database transformations by fetching existing models and inserting new ones."}],"identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/ComplexMigrations"},"doc://VeinCore/tutorials/VeinCore/Quick-start-Swift-Package#Create-your-first-Model":{"kind":"section","type":"section","identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Quick-start-Swift-Package#Create-your-first-Model","title":"Create your first Model","abstract":[{"text":"Install VeinCore and create your first model.","type":"text"}],"url":"\/tutorials\/veincore\/quick-start-swift-package#Create-your-first-Model","role":"pseudoSymbol"},"doc://VeinCore/tutorials/VeinCore/Quick-start-Xcode#ModelContainer--ManagedObjectContext":{"title":"ModelContainer & ManagedObjectContext","identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Quick-start-Xcode#ModelContainer--ManagedObjectContext","kind":"section","type":"section","abstract":[{"type":"text","text":"Install VeinCore and create your first model."}],"url":"\/tutorials\/veincore\/quick-start-xcode#ModelContainer--ManagedObjectContext","role":"pseudoSymbol"}}}