{"kind":"project","identifier":{"url":"doc:\/\/VeinCore\/tutorials\/VeinCore\/ComplexMigrations","interfaceLanguage":"swift"},"sections":[{"kind":"hero","content":[{"inlineContent":[{"text":"Handle structural database transformations by fetching existing models and inserting new ones.","type":"text"}],"type":"paragraph"}],"chapter":"Complex Migrations","estimatedTimeInMinutes":7,"title":"Complex Migrations"},{"kind":"tasks","tasks":[{"anchor":"Writing-Custom-Migration-Logic","stepsSection":[{"runtimePreview":null,"code":"complex-migration-schemas.swift","content":[{"inlineContent":[{"type":"text","text":"Define the baseline and destination schemas. Notice that "},{"type":"codeVoice","code":"V0_0_2.Test"},{"type":"text","text":" now requires a non-optional "},{"type":"codeVoice","code":"securityCode"},{"type":"text","text":" instead of "},{"type":"codeVoice","code":"randomValue"},{"type":"text","text":", meaning simple column additions won’t work."}],"type":"paragraph"}],"type":"step","caption":[],"media":null},{"type":"step","content":[{"inlineContent":[{"text":"Set up your ","type":"text"},{"code":"SchemaMigrationPlan","type":"codeVoice"},{"text":" block, preparing a ","type":"text"},{"code":".complex","type":"codeVoice"},{"text":" transition stage from version 1 to version 2.","type":"text"}],"type":"paragraph"}],"media":null,"code":"complex-migration-stages-1.swift","caption":[],"runtimePreview":null},{"content":[{"inlineContent":[{"type":"text","text":"Implement the migration logic. Fetch the baseline records, execute your custom business rules, and save the mapped models back to the new schema inside the transition step."}],"type":"paragraph"}],"media":null,"code":"complex-migration-stages-2.swift","caption":[],"runtimePreview":null,"type":"step"}],"title":"Writing Custom Migration Logic","contentSection":[{"content":[{"inlineContent":[{"text":"Simple migration helpers are great for adding fields or dropping tables. However, when you rename fields, merge schemas, or modify non-optional data types (like mapping an ","type":"text"},{"type":"codeVoice","code":"Int"},{"text":" to a formatted ","type":"text"},{"type":"codeVoice","code":"String"},{"text":"), you need a custom migration.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"In this tutorial, we will migrate from ","type":"text"},{"code":"V0_0_1","type":"codeVoice"},{"text":" to ","type":"text"},{"code":"V0_0_2","type":"codeVoice"},{"text":" where we:","type":"text"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Map an old model’s field "},{"type":"codeVoice","code":"randomValue"},{"type":"text","text":" (Int) into a formatted "},{"type":"codeVoice","code":"securityCode"},{"type":"text","text":" (String)."}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Apply processing rules during the transfer (clamping negative numbers to zero)."}],"type":"paragraph"}]}]}],"mediaPosition":"trailing","kind":"contentAndMedia"}]}]},{"abstract":[{"text":"Make your own types persistable.","type":"text"}],"action":{"overridingTitle":"Get started","isActive":true,"identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/CustomPersistable","overridingTitleInlineContent":[{"type":"text","text":"Get started"}],"type":"reference"},"kind":"callToAction","featuredEyebrow":"Tutorial","title":"Custom Persistable"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/tutorials\/veincore\/complexmigrations"]}],"metadata":{"categoryPathComponent":"Table-of-Contents","category":"Vein","role":"project","title":"Complex Migrations"},"hierarchy":{"reference":"doc:\/\/VeinCore\/tutorials\/Table-of-Contents","modules":[{"reference":"doc:\/\/VeinCore\/tutorials\/Table-of-Contents\/Quick-start","projects":[{"sections":[{"reference":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Quick-start-Swift-Package#Setup","kind":"task"},{"reference":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Quick-start-Swift-Package#Create-your-first-Model","kind":"task"},{"reference":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Quick-start-Swift-Package#ModelContainer--ManagedObjectContext","kind":"task"}],"reference":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Quick-start-Swift-Package"},{"sections":[{"reference":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Quick-start-Xcode#Setup","kind":"task"},{"reference":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Quick-start-Xcode#Create-your-first-Model","kind":"task"},{"reference":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Quick-start-Xcode#ModelContainer--ManagedObjectContext","kind":"task"}],"reference":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Quick-start-Xcode"}]},{"reference":"doc:\/\/VeinCore\/tutorials\/Table-of-Contents\/Relationships","projects":[{"reference":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Relationships","sections":[{"kind":"task","reference":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Relationships#Adding-a-relationship-to-our-model"},{"kind":"task","reference":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Relationships#Persisting--fetching-a-relationship"}]}]},{"reference":"doc:\/\/VeinCore\/tutorials\/Table-of-Contents\/Simple-Migrations","projects":[{"sections":[{"kind":"task","reference":"doc:\/\/VeinCore\/tutorials\/VeinCore\/SimpleMigrations#Migrating-Schemas"}],"reference":"doc:\/\/VeinCore\/tutorials\/VeinCore\/SimpleMigrations"}]},{"reference":"doc:\/\/VeinCore\/tutorials\/Table-of-Contents\/Complex-Migrations","projects":[{"sections":[{"kind":"task","reference":"doc:\/\/VeinCore\/tutorials\/VeinCore\/ComplexMigrations#Writing-Custom-Migration-Logic"}],"reference":"doc:\/\/VeinCore\/tutorials\/VeinCore\/ComplexMigrations"}]},{"reference":"doc:\/\/VeinCore\/tutorials\/Table-of-Contents\/Custom-Persistable","projects":[{"reference":"doc:\/\/VeinCore\/tutorials\/VeinCore\/CustomPersistable","sections":[{"reference":"doc:\/\/VeinCore\/tutorials\/VeinCore\/CustomPersistable#RawRepresentable","kind":"task"},{"reference":"doc:\/\/VeinCore\/tutorials\/VeinCore\/CustomPersistable#Codable","kind":"task"},{"reference":"doc:\/\/VeinCore\/tutorials\/VeinCore\/CustomPersistable#Manual-Persistable","kind":"task"}]}]}],"paths":[["doc:\/\/VeinCore\/tutorials\/Table-of-Contents","doc:\/\/VeinCore\/tutorials\/Table-of-Contents\/$volume","doc:\/\/VeinCore\/tutorials\/Table-of-Contents\/Complex-Migrations"]]},"schemaVersion":{"patch":0,"major":0,"minor":3},"references":{"doc://VeinCore/tutorials/VeinCore/CustomPersistable":{"estimatedTime":"5min","identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/CustomPersistable","kind":"project","title":"Custom Persistable","role":"project","url":"\/tutorials\/veincore\/custompersistable","abstract":[{"text":"Make your own types persistable.","type":"text"}],"type":"topic"},"doc://VeinCore/tutorials/VeinCore/Quick-start-Xcode#ModelContainer--ManagedObjectContext":{"identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Quick-start-Xcode#ModelContainer--ManagedObjectContext","title":"ModelContainer & ManagedObjectContext","type":"section","abstract":[{"text":"Install VeinCore and create your first model.","type":"text"}],"role":"pseudoSymbol","url":"\/tutorials\/veincore\/quick-start-xcode#ModelContainer--ManagedObjectContext","kind":"section"},"doc://VeinCore/tutorials/Table-of-Contents/Custom-Persistable":{"type":"topic","title":"Custom Persistable","kind":"article","role":"article","abstract":[],"identifier":"doc:\/\/VeinCore\/tutorials\/Table-of-Contents\/Custom-Persistable","url":"\/tutorials\/table-of-contents\/custom-persistable"},"complex-migration-schemas.swift":{"syntax":"swift","highlights":[],"content":["import VeinCore","","\/\/ Our baseline schema","enum V0_0_1: VersionedSchema {","    static let version = ModelVersion(0, 0, 1)","    static let models: [any PersistentModel.Type] = [","        Test.self","    ]","    ","    @Model","    final class Test {","        var flag: Bool","        var someValue: String","        var randomValue: Int","        ","        init(flag: Bool, someValue: String, randomValue: Int) {","            self.flag = flag","            self.someValue = someValue","            self.randomValue = randomValue","        }","    }","}","","\/\/ Our destination schema","enum V0_0_2: VersionedSchema {","    static let version = ModelVersion(0, 0, 2)","    static let models: [any PersistentModel.Type] = [Test.self]","    ","    @Model","    final class Test {","        var flag: Bool","        var someValue: String","        var securityCode: String \/\/ This replaces the old raw Int","        ","        init(flag: Bool, someValue: String, securityCode: String) {","            self.flag = flag","            self.someValue = someValue","            self.securityCode = securityCode","        }","    }","}"],"type":"file","fileName":"Schemas.swift","identifier":"complex-migration-schemas.swift","fileType":"swift"},"doc://VeinCore/tutorials/VeinCore/Quick-start-Swift-Package#Create-your-first-Model":{"kind":"section","url":"\/tutorials\/veincore\/quick-start-swift-package#Create-your-first-Model","role":"pseudoSymbol","type":"section","abstract":[{"type":"text","text":"Install VeinCore and create your first model."}],"title":"Create your first Model","identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Quick-start-Swift-Package#Create-your-first-Model"},"doc://VeinCore/tutorials/VeinCore/Quick-start-Swift-Package#ModelContainer--ManagedObjectContext":{"identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Quick-start-Swift-Package#ModelContainer--ManagedObjectContext","role":"pseudoSymbol","abstract":[{"text":"Install VeinCore and create your first model.","type":"text"}],"title":"ModelContainer & ManagedObjectContext","type":"section","url":"\/tutorials\/veincore\/quick-start-swift-package#ModelContainer--ManagedObjectContext","kind":"section"},"doc://VeinCore/tutorials/VeinCore/ComplexMigrations":{"kind":"project","url":"\/tutorials\/veincore\/complexmigrations","type":"topic","identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/ComplexMigrations","title":"Complex Migrations","abstract":[{"text":"Handle structural database transformations by fetching existing models and inserting new ones.","type":"text"}],"estimatedTime":"7min","role":"project"},"doc://VeinCore/tutorials/Table-of-Contents/Complex-Migrations":{"kind":"article","role":"article","title":"Complex Migrations","abstract":[],"type":"topic","identifier":"doc:\/\/VeinCore\/tutorials\/Table-of-Contents\/Complex-Migrations","url":"\/tutorials\/table-of-contents\/complex-migrations"},"doc://VeinCore/tutorials/Table-of-Contents/Quick-start":{"abstract":[],"url":"\/tutorials\/table-of-contents\/quick-start","identifier":"doc:\/\/VeinCore\/tutorials\/Table-of-Contents\/Quick-start","kind":"article","role":"article","type":"topic","title":"Quick start"},"doc://VeinCore/tutorials/VeinCore/Relationships":{"url":"\/tutorials\/veincore\/relationships","abstract":[{"type":"text","text":"Use relationships with VeinCore."}],"estimatedTime":"3min","title":"Relationships","role":"project","identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Relationships","type":"topic","kind":"project"},"doc://VeinCore/tutorials/VeinCore/Quick-start-Xcode":{"kind":"project","type":"topic","url":"\/tutorials\/veincore\/quick-start-xcode","identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Quick-start-Xcode","title":"Quick start Xcode","abstract":[{"type":"text","text":"Install VeinCore and create your first model."}],"estimatedTime":"5min","role":"project"},"doc://VeinCore/tutorials/VeinCore/Quick-start-Swift-Package":{"kind":"project","type":"topic","url":"\/tutorials\/veincore\/quick-start-swift-package","identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Quick-start-Swift-Package","title":"Quick start Swift Package","abstract":[{"text":"Install VeinCore and create your first model.","type":"text"}],"estimatedTime":"5min","role":"project"},"complex-migration-stages-1.swift":{"fileName":"Migration.swift","type":"file","content":["import VeinCore","","enum ComplexMigration: SchemaMigrationPlan {","    static var schemas: [any VersionedSchema.Type] {","        [V0_0_1.self, V0_0_2.self]","    }","    ","    static var stages: [MigrationStage] {","        [migrateV1toV2]","    }","    ","    static let migrateV1toV2 = MigrationStage.complex(","        fromVersion: V0_0_1.self,","        toVersion: V0_0_2.self,","        willMigrate: { context in","            \/\/ Custom mapping logic will go here","        },","        didMigrate: nil","    )","}"],"syntax":"swift","identifier":"complex-migration-stages-1.swift","fileType":"swift","highlights":[]},"doc://VeinCore/tutorials/Table-of-Contents/Relationships":{"kind":"article","role":"article","title":"Relationships","abstract":[],"type":"topic","identifier":"doc:\/\/VeinCore\/tutorials\/Table-of-Contents\/Relationships","url":"\/tutorials\/table-of-contents\/relationships"},"doc://VeinCore/tutorials/VeinCore/ComplexMigrations#Writing-Custom-Migration-Logic":{"role":"pseudoSymbol","type":"section","url":"\/tutorials\/veincore\/complexmigrations#Writing-Custom-Migration-Logic","abstract":[{"type":"text","text":"Handle structural database transformations by fetching existing models and inserting new ones."}],"identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/ComplexMigrations#Writing-Custom-Migration-Logic","kind":"section","title":"Writing Custom Migration Logic"},"doc://VeinCore/tutorials/VeinCore/CustomPersistable#Codable":{"abstract":[{"text":"Make your own types persistable.","type":"text"}],"kind":"section","title":"Codable","role":"pseudoSymbol","url":"\/tutorials\/veincore\/custompersistable#Codable","identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/CustomPersistable#Codable","type":"section"},"doc://VeinCore/tutorials/VeinCore/Quick-start-Xcode#Setup":{"kind":"section","identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Quick-start-Xcode#Setup","role":"pseudoSymbol","title":"Setup","abstract":[{"type":"text","text":"Install VeinCore and create your first model."}],"url":"\/tutorials\/veincore\/quick-start-xcode#Setup","type":"section"},"doc://VeinCore/tutorials/VeinCore/Quick-start-Xcode#Create-your-first-Model":{"identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Quick-start-Xcode#Create-your-first-Model","title":"Create your first Model","abstract":[{"type":"text","text":"Install VeinCore and create your first model."}],"type":"section","role":"pseudoSymbol","url":"\/tutorials\/veincore\/quick-start-xcode#Create-your-first-Model","kind":"section"},"doc://VeinCore/tutorials/VeinCore/Quick-start-Swift-Package#Setup":{"abstract":[{"type":"text","text":"Install VeinCore and create your first model."}],"url":"\/tutorials\/veincore\/quick-start-swift-package#Setup","title":"Setup","kind":"section","role":"pseudoSymbol","identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Quick-start-Swift-Package#Setup","type":"section"},"complex-migration-stages-2.swift":{"highlights":[],"fileName":"Migration.swift","identifier":"complex-migration-stages-2.swift","content":["import VeinCore","","enum ComplexMigration: SchemaMigrationPlan {","    static var schemas: [any VersionedSchema.Type] {","        [V0_0_1.self, V0_0_2.self]","    }","    ","    static var stages: [MigrationStage] {","        [migrateV1toV2]","    }","    ","    static let migrateV1toV2 = MigrationStage.complex(","        fromVersion: V0_0_1.self,","        toVersion: V0_0_2.self,","        willMigrate: { context in","            \/\/ 1. Fetch current models from the V1 database setup","            let oldTests = try context.fetchAll(V0_0_1.Test.self)","            ","            \/\/ 2. Map old entries to new types individually","            for test in oldTests {","                let sanitizedValue = max(0, test.randomValue)","                ","                let newTest = V0_0_2.Test(","                    flag: test.flag,","                    someValue: test.someValue,","                    securityCode: \"SEC-\\(sanitizedValue)\"","                )","                ","                \/\/ Add the new instance and remove the old one.","                \/\/ If a migration has unhandled non-empty tables at the end it will fail.","                try context.insert(newTest)","                try context.delete(test)","            }","        },","        didMigrate: nil","    )","}"],"syntax":"swift","fileType":"swift","type":"file"},"doc://VeinCore/tutorials/VeinCore/Relationships#Adding-a-relationship-to-our-model":{"kind":"section","type":"section","url":"\/tutorials\/veincore\/relationships#Adding-a-relationship-to-our-model","abstract":[{"type":"text","text":"Use relationships with VeinCore."}],"identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Relationships#Adding-a-relationship-to-our-model","title":"Adding a relationship to our model","role":"pseudoSymbol"},"doc://VeinCore/tutorials/VeinCore/CustomPersistable#RawRepresentable":{"title":"RawRepresentable","kind":"section","identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/CustomPersistable#RawRepresentable","type":"section","role":"pseudoSymbol","url":"\/tutorials\/veincore\/custompersistable#RawRepresentable","abstract":[{"text":"Make your own types persistable.","type":"text"}]},"doc://VeinCore/tutorials/VeinCore/SimpleMigrations#Migrating-Schemas":{"abstract":[{"text":"Effortlessly & safely evolve your database schema using stage-by-stage migrations & Vein helper functions.","type":"text"}],"url":"\/tutorials\/veincore\/simplemigrations#Migrating-Schemas","title":"Migrating Schemas","kind":"section","role":"pseudoSymbol","identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/SimpleMigrations#Migrating-Schemas","type":"section"},"doc://VeinCore/tutorials/Table-of-Contents":{"title":"Meet Vein","role":"overview","abstract":[{"type":"text","text":"Database for apps made easy."}],"identifier":"doc:\/\/VeinCore\/tutorials\/Table-of-Contents","url":"\/tutorials\/table-of-contents","kind":"overview","type":"topic"},"doc://VeinCore/tutorials/Table-of-Contents/Simple-Migrations":{"role":"article","abstract":[],"kind":"article","url":"\/tutorials\/table-of-contents\/simple-migrations","type":"topic","identifier":"doc:\/\/VeinCore\/tutorials\/Table-of-Contents\/Simple-Migrations","title":"Simple Migrations"},"doc://VeinCore/tutorials/VeinCore/CustomPersistable#Manual-Persistable":{"abstract":[{"text":"Make your own types persistable.","type":"text"}],"identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/CustomPersistable#Manual-Persistable","type":"section","url":"\/tutorials\/veincore\/custompersistable#Manual-Persistable","kind":"section","title":"Manual Persistable","role":"pseudoSymbol"},"doc://VeinCore/tutorials/VeinCore/Relationships#Persisting--fetching-a-relationship":{"role":"pseudoSymbol","url":"\/tutorials\/veincore\/relationships#Persisting--fetching-a-relationship","type":"section","abstract":[{"text":"Use relationships with VeinCore.","type":"text"}],"identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Relationships#Persisting--fetching-a-relationship","kind":"section","title":"Persisting & fetching a relationship"},"doc://VeinCore/tutorials/VeinCore/SimpleMigrations":{"role":"project","identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/SimpleMigrations","url":"\/tutorials\/veincore\/simplemigrations","estimatedTime":"5min","kind":"project","abstract":[{"type":"text","text":"Effortlessly & safely evolve your database schema using stage-by-stage migrations & Vein helper functions."}],"title":"Simple Database Migrations","type":"topic"}}}