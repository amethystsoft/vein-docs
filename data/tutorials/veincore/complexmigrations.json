{"identifier":{"url":"doc:\/\/VeinCore\/tutorials\/VeinCore\/ComplexMigrations","interfaceLanguage":"swift"},"kind":"project","schemaVersion":{"major":0,"patch":0,"minor":3},"hierarchy":{"reference":"doc:\/\/VeinCore\/tutorials\/Table-of-Contents","paths":[["doc:\/\/VeinCore\/tutorials\/Table-of-Contents","doc:\/\/VeinCore\/tutorials\/Table-of-Contents\/$volume","doc:\/\/VeinCore\/tutorials\/Table-of-Contents\/Complex-Migrations"]],"modules":[{"projects":[{"sections":[{"reference":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Quick-start-Swift-Package#Setup","kind":"task"},{"kind":"task","reference":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Quick-start-Swift-Package#Create-your-first-Model"},{"kind":"task","reference":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Quick-start-Swift-Package#ModelContainer--ManagedObjectContext"}],"reference":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Quick-start-Swift-Package"},{"sections":[{"reference":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Quick-start-Xcode#Setup","kind":"task"},{"reference":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Quick-start-Xcode#Create-your-first-Model","kind":"task"},{"reference":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Quick-start-Xcode#ModelContainer--ManagedObjectContext","kind":"task"}],"reference":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Quick-start-Xcode"}],"reference":"doc:\/\/VeinCore\/tutorials\/Table-of-Contents\/Quick-start"},{"projects":[{"reference":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Relationships","sections":[{"reference":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Relationships#Adding-a-relationship-to-our-model","kind":"task"},{"kind":"task","reference":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Relationships#Persisting--fetching-a-relationship"}]}],"reference":"doc:\/\/VeinCore\/tutorials\/Table-of-Contents\/Relationships"},{"reference":"doc:\/\/VeinCore\/tutorials\/Table-of-Contents\/Simple-Migrations","projects":[{"reference":"doc:\/\/VeinCore\/tutorials\/VeinCore\/SimpleMigrations","sections":[{"reference":"doc:\/\/VeinCore\/tutorials\/VeinCore\/SimpleMigrations#Migrating-Schemas","kind":"task"}]}]},{"reference":"doc:\/\/VeinCore\/tutorials\/Table-of-Contents\/Complex-Migrations","projects":[{"reference":"doc:\/\/VeinCore\/tutorials\/VeinCore\/ComplexMigrations","sections":[{"reference":"doc:\/\/VeinCore\/tutorials\/VeinCore\/ComplexMigrations#Writing-Custom-Migration-Logic","kind":"task"}]}]}]},"variants":[{"paths":["\/tutorials\/veincore\/complexmigrations"],"traits":[{"interfaceLanguage":"swift"}]}],"sections":[{"kind":"hero","estimatedTimeInMinutes":7,"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Handle structural database transformations by fetching existing models and inserting new ones."}]}],"title":"Complex Migrations","chapter":"Complex Migrations"},{"tasks":[{"stepsSection":[{"code":"complex-migration-schemas.swift","runtimePreview":null,"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Define the baseline and destination schemas. Notice that "},{"type":"codeVoice","code":"V0_0_2.Test"},{"type":"text","text":" now requires a non-optional "},{"type":"codeVoice","code":"securityCode"},{"type":"text","text":" instead of "},{"type":"codeVoice","code":"randomValue"},{"type":"text","text":", meaning simple column additions won’t work."}]}],"caption":[],"type":"step","media":null},{"code":"complex-migration-stages-1.swift","runtimePreview":null,"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Set up your "},{"code":"SchemaMigrationPlan","type":"codeVoice"},{"type":"text","text":" block, preparing a "},{"code":".complex","type":"codeVoice"},{"type":"text","text":" transition stage from version 1 to version 2."}]}],"caption":[],"type":"step","media":null},{"code":"complex-migration-stages-2.swift","runtimePreview":null,"content":[{"inlineContent":[{"text":"Implement the migration logic. Fetch the baseline records, execute your custom business rules, and save the mapped models back to the new schema inside the transition step.","type":"text"}],"type":"paragraph"}],"caption":[],"type":"step","media":null}],"anchor":"Writing-Custom-Migration-Logic","contentSection":[{"content":[{"inlineContent":[{"text":"Simple migration helpers are great for adding fields or dropping tables. However, when you rename fields, merge schemas, or modify non-optional data types (like mapping an ","type":"text"},{"code":"Int","type":"codeVoice"},{"text":" to a formatted ","type":"text"},{"code":"String","type":"codeVoice"},{"text":"), you need a custom migration.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"In this tutorial, we will migrate from ","type":"text"},{"code":"V0_0_1","type":"codeVoice"},{"text":" to ","type":"text"},{"code":"V0_0_2","type":"codeVoice"},{"text":" where we:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Map an old model’s field "},{"code":"randomValue","type":"codeVoice"},{"type":"text","text":" (Int) into a formatted "},{"code":"securityCode","type":"codeVoice"},{"type":"text","text":" (String)."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Apply processing rules during the transfer (clamping negative numbers to zero).","type":"text"}]}]}],"type":"unorderedList"}],"mediaPosition":"trailing","kind":"contentAndMedia"}],"title":"Writing Custom Migration Logic"}],"kind":"tasks"}],"metadata":{"categoryPathComponent":"Table-of-Contents","category":"Vein","title":"Complex Migrations","role":"project"},"references":{"doc://VeinCore/tutorials/VeinCore/Quick-start-Xcode":{"type":"topic","url":"\/tutorials\/veincore\/quick-start-xcode","kind":"project","identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Quick-start-Xcode","role":"project","title":"Quick start Xcode","abstract":[{"type":"text","text":"Install VeinCore and create your first model."}],"estimatedTime":"5min"},"doc://VeinCore/tutorials/VeinCore/Relationships#Persisting--fetching-a-relationship":{"type":"s