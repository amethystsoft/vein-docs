ntents\/Complex-Migrations"},{"projects":[{"sections":[{"kind":"task","reference":"doc:\/\/VeinCore\/tutorials\/VeinCore\/CustomPersistable#RawRepresentable"},{"kind":"task","reference":"doc:\/\/VeinCore\/tutorials\/VeinCore\/CustomPersistable#Codable"},{"kind":"task","reference":"doc:\/\/VeinCore\/tutorials\/VeinCore\/CustomPersistable#Manual-Persistable"}],"reference":"doc:\/\/VeinCore\/tutorials\/VeinCore\/CustomPersistable"}],"reference":"doc:\/\/VeinCore\/tutorials\/Table-of-Contents\/Custom-Persistable"}],"paths":[["doc:\/\/VeinCore\/tutorials\/Table-of-Contents","doc:\/\/VeinCore\/tutorials\/Table-of-Contents\/$volume","doc:\/\/VeinCore\/tutorials\/Table-of-Contents\/Simple-Migrations"]]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/tutorials\/veincore\/simplemigrations"]}],"metadata":{"role":"project","category":"Vein","categoryPathComponent":"Table-of-Contents","title":"Simple Database Migrations"},"sections":[{"chapter":"Simple Migrations","kind":"hero","title":"Simple Database Migrations","estimatedTimeInMinutes":5,"content":[{"inlineContent":[{"type":"text","text":"Effortlessly & safely evolve your database schema using stage-by-stage migrations & Vein helper functions."}],"type":"paragraph"}]},{"tasks":[{"stepsSection":[{"type":"step","runtimePreview":null,"media":null,"code":"migration-schemas.swift","caption":[],"content":[{"inlineContent":[{"type":"text","text":"Define your next schema version. In "},{"type":"codeVoice","code":"V0_0_2"},{"type":"text","text":", we declare our updated models."},{"type":"text","text":" "},{"type":"text","text":"Note that the new property "},{"type":"codeVoice","code":"rating"},{"type":"text","text":" must be an optional value."}],"type":"paragraph"}]},{"type":"step","runtimePreview":null,"media":null,"code":"migration-stages-1.swift","caption":[],"content":[{"inlineContent":[{"type":"text","text":"Now, create your "},{"type":"codeVoice","code":"SchemaMigrationPlan"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"You list your supported schemas in chronological order and define the transitions in the "},{"type":"codeVoice","code":"stages"},{"type":"text","text":" array."}],"type":"paragraph"}]},{"type":"step","runtimePreview":null,"media":null,"code":"migration-stages-2.swift","caption":[],"content":[{"inlineContent":[{"type":"text","text":"Inside the "},{"type":"codeVoice","code":"willMigrate"},{"type":"text","text":" phase, utilize Vein’s migration helpers."},{"type":"text","text":" "},{"type":"text","text":"Use "},{"type":"codeVoice","code":"unchangedMigration"},{"type":"text","text":" to keep a table intact, "},{"type":"codeVoice","code":"deleteMigration"},{"type":"text","text":" to drop a table, and "},{"type":"codeVoice","code":"fieldsAddedMigration"},{"type":"text","text":" to safely append the new optional column."}],"type":"paragraph"}]}],"contentSection":[{"kind":"contentAndMedia","mediaPosition":"trailing","content":[{"type":"paragraph","inlineContent":[{"text":"As your app grows, you will inevitably need to change your data models.","type":"text"},{"text":" ","type":"text"},{"text":"Vein handles this through explicit, compile-time typesafe migrations.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"In this guide, we will migrate from V0_0_1 to V0_0_2. During this change:"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"codeVoice","code":"Post"},{"type":"text","text":" remains unchanged."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"code":"Attachment","type":"codeVoice"},{"text":" receives a new optional ","type":"text"},{"code":"rating","type":"codeVoice"},{"text":" field.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A legacy class "},{"type":"codeVoice","code":"Unused"},{"type":"text","text":" is completely deleted."}]}]}]}]}],"title":"Migrating Schemas","anchor":"Migrating-Schemas"}],"kind":"tasks"},{"abstract":[{"type":"text","text":"Handle structural database transformations by fetching existing models and inserting new ones."}],"kind":"callToAction","title":"Complex Migrations","action":{"overridingTitle":"Get started","identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/ComplexMigrations","type":"reference","isActive":true,"overridingTitleInlineContent":[{"text":"Get started","type":"text"}]},"featuredEyebrow":"Tutorial"}],"identifier":{"url":"doc:\/\/VeinCore\/tutorials\/VeinCore\/SimpleMigrations","interfaceLanguage":"swift"},"schemaVersion":{"major":0,"minor":3,"patch":0},"kind":"project","references":{"doc://VeinCore/tutorials/VeinCore/Quick-start-Xcode#ModelContainer--ManagedObjectContext":{"identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Quick-start-Xcode#ModelContainer--ManagedObjectContext","title":"ModelContainer & ManagedObjectContext","type":"section","abstract":[{"text":"Install VeinCore and create your first model.","type":"text"}],"role":"pseudoSymbol","url":"\/tutorials\/veincore\/quick-start-xcode#ModelContainer--ManagedObjectContext","kind":"section"},"migration-stages-1.swift":{"identifier":"migration-stages-1.swift","content":["import VeinCore","","enum Migration: SchemaMigrationPlan {","    static var schemas: [any VersionedSchema.Type] {","        [","            V0_0_1.self,","            V0_0_2.self","        ]","    }","    ","    static var stages: [MigrationStage] {","        [","            migrateV1toV2","        ]","    }","    ","    static let migrateV1toV2 = MigrationStage.complex(","        fromVersion: V0_0_1.self,","        toVersion: V0_0_2.self,","        willMigrate: { context in","            \/\/ Migration helpers will go here...","        },","        didMigrate: nil","    )","}"],"syntax":"swift","fileType":"swift","type":"file","highlights":[],"fileName":"Migration.swift"},"doc://VeinCore/tutorials/VeinCore/Quick-start-Xcode#Setup":{"kind":"section","identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Quick-start-Xcode#Setup","role":"pseudoSymbol","title":"Setup","abstract":[{"type":"text","text":"Install VeinCore and create your first model."}],"url":"\/tutorials\/veincore\/quick-start-xcode#Setup","type":"section"},"doc://VeinCore/tutorials/VeinCore/CustomPersistable":{"type":"topic","kind":"project","role":"project","url":"\/tutorials\/veincore\/custompersistable","identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/CustomPersistable","estimatedTime":"5min","title":"Custom Persistable","abstract":[{"type":"text","text":"Make your own types persistable."}]},"doc://VeinCore/tutorials/VeinCore/CustomPersistable#Manual-Persistable":{"abstract":[{"text":"Make your own types persistable.","type":"text"}],"identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/CustomPersistable#Manual-Persistable","type":"section","url":"\/tutorials\/veincore\/custompersistable#Manual-Persistable","kind":"section","title":"Manual Persistable","role":"pseudoSymbol"},"migration-stages-2.swift":{"syntax":"swift","identifier":"migration-stages-2.swift","highlights":[],"fileType":"swift","type":"file","fileName":"Migration.swift","content":["import VeinCore","","enum Migration: SchemaMigrationPlan {","    static var schemas: [any VersionedSchema.Type] {","        [V0_0_1.self, V0_0_2.self]","    }","    ","    static var stages: [MigrationStage] {","        [migrateV1toV2]","    }","    ","    static let migrateV1toV2 = MigrationStage.complex(","        fromVersion: V0_0_1.self,","        toVersion: V0_0_2.self,","        willMigrate: { context in","            \/\/ 1. Unchanged models must still be carried over","            try V0_0_1.Post.unchangedMigration(","                to: V0_0_2.Post.self,","                on: context","            )","            ","            \/\/ 2. Safely introduce the newly added optional fields","            try V0_0_1.Attachment.fieldsAddedMigration(","                to: V0_0_2.Attachment.self,","                on: context","            )","            ","            \/\/ 3. Drop tables\/data you no longer require","            try V0_0_1.Unused.deleteMigration(on: context)","        },","        didMigrate: nil","    )","}"]},"doc://VeinCore/tutorials/VeinCore/Quick-start-Swift-Package#ModelContainer--ManagedObjectContext":{"identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Quick-start-Swift-Package#ModelContainer--ManagedObjectContext","role":"pseudoSymbol","abstract":[{"text":"Install VeinCore and create your first model.","type":"text"}],"title":"ModelContainer & ManagedObjectContext","type":"section","url":"\/tutorials\/veincore\/quick-start-swift-package#ModelContainer--ManagedObjectContext","kind":"section"},"doc://VeinCore/tutorials/VeinCore/CustomPersistable#Codable":{"abstract":[{"text":"Make your own types persistable.","type":"text"}],"kind":"section","title":"Codable","role":"pseudoSymbol","url":"\/tutorials\/veincore\/custompersistable#Codable","identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/CustomPersistable#Codable","type":"section"},"doc://VeinCore/tutorials/Table-of-Contents/Complex-Migrations":{"kind":"article","role":"article","title":"Complex Migrations","abstract":[],"type":"topic","identifier":"doc:\/\/VeinCore\/tutorials\/Table-of-Contents\/Complex-Migrations","url":"\/tutorials\/table-of-contents\/complex-migrations"},"doc://VeinCore/tutorials/Table-of-Contents/Quick-start":{"identifier":"doc:\/\/VeinCore\/tutorials\/Table-of-Contents\/Quick-start","title":"Quick start","abstract":[],"type":"topic","role":"article","url":"\/tutorials\/table-of-contents\/quick-start","kind":"article"},"doc://VeinCore/tutorials/VeinCore/SimpleMigrations#Migrating-Schemas":{"abstract":[{"text":"Effortlessly & safely evolve your database schema using stage-by-stage migrations & Vein helper functions.","type":"text"}],"url":"\/tutorials\/veincore\/simplemigrations#Migrating-Schemas","title":"Migrating Schemas","kind":"section","role":"pseudoSymbol","identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/SimpleMigrations#Migrating-Schemas","type":"section"},"doc://VeinCore/tutorials/Table-of-Contents/Custom-Persistable":{"type":"topic","title":"Custom Persistable","kind":"article","role":"article","abstract":[],"identifier":"doc:\/\/VeinCore\/tutorials\/Table-of-Contents\/Custom-Persistable","url":"\/tutorials\/table-of-contents\/custom-persistable"},"doc://VeinCore/tutorials/Table-of-Contents/Relationships":{"kind":"article","role":"article","title":"Relationships","abstract":[],"type":"topic","identifier":"doc:\/\/VeinCore\/tutorials\/Table-of-Contents\/Relationships","url":"\/tutorials\/table-of-contents\/relationships"},"doc://VeinCore/tutorials/VeinCore/Quick-start-Swift-Package#Setup":{"abstract":[{"type":"text","text":"Install VeinCore and create your first model."}],"url":"\/tutorials\/veincore\/quick-start-swift-package#Setup","title":"Setup","kind":"section","role":"pseudoSymbol","identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Quick-start-Swift-Package#Setup","type":"section"},"doc://VeinCore/tutorials/VeinCore/Quick-start-Xcode#Create-your-first-Model":{"identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Quick-start-Xcode#Create-your-first-Model","title":"Create your first Model","abstract":[{"type":"text","text":"Install VeinCore and create your first model."}],"type":"section","role":"pseudoSymbol","url":"\/tutorials\/veincore\/quick-start-xcode#Create-your-first-Model","kind":"section"},"doc://VeinCore/tutorials/Table-of-Contents/Simple-Migrations":{"role":"article","abstract":[],"kind":"article","url":"\/tutorials\/table-of-contents\/simple-migrations","type":"topic","identifier":"doc:\/\/VeinCore\/tutorials\/Table-of-Contents\/Simple-Migrations","title":"Simple Migrations"},"doc://VeinCore/tutorials/VeinCore/Relationships#Persisting--fetching-a-relationship":{"role":"pseudoSymbol","url":"\/tutorials\/veincore\/relationships#Persisting--fetching-a-relationship","type":"section","abstract":[{"text":"Use relationships with VeinCore.","type":"text"}],"identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Relationships#Persisting--fetching-a-relationship","kind":"section","title":"Persisting & fetching a relationship"},"migration-schemas.swift":{"identifier":"migration-schemas.swift","content":["import VeinCore","","\/\/ Our baseline schema","enum V0_0_1: VersionedSchema {","    static let version = ModelVersion(0, 0, 1)","    static let models: [any PersistentModel.Type] = [","        Post.self, Attachment.self, Unused.self","    ]","    ","    @Model final class Post { var title: String \/*...*\/ }","    @Model final class Attachment { var name: String \/*...*\/ }","    @Model final class Unused { var content: String \/*...*\/ }","}","","\/\/ Our destination schema","enum V0_0_2: VersionedSchema {","    static let version = ModelVersion(0, 0, 2)","    static let models: [any PersistentModel.Type] = [","        Post.self, Attachment.self","    ]","    ","    @Model final class Post { var title: String }","    ","    @Model final class Attachment {","        var name: String","        ","        \/\/ New optional field allows safe column additions","        var rating: Int?","    }","}"],"syntax":"swift","fileType":"swift","type":"file","highlights":[],"fileName":"Schemas.swift"},"doc://VeinCore/tutorials/VeinCore/ComplexMigrations#Writing-Custom-Migration-Logic":{"role":"pseudoSymbol","type":"section","url":"\/tutorials\/veincore\/complexmigrations#Writing-Custom-Migration-Logic","abstract":[{"type":"text","text":"Handle structural database transformations by fetching existing models and inserting new ones."}],"identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/ComplexMigrations#Writing-Custom-Migration-Logic","kind":"section","title":"Writing Custom Migration Logic"},"doc://VeinCore/tutorials/VeinCore/Quick-start-Xcode":{"kind":"project","type":"topic","url":"\/tutorials\/veincore\/quick-start-xcode","identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Quick-start-Xcode","title":"Quick start Xcode","abstra