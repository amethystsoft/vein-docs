{"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/tutorials\/veincore\/simplemigrations"]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"kind":"project","metadata":{"categoryPathComponent":"Table-of-Contents","role":"project","title":"Simple Database Migrations","category":"Vein"},"identifier":{"url":"doc:\/\/VeinCore\/tutorials\/VeinCore\/SimpleMigrations","interfaceLanguage":"swift"},"sections":[{"kind":"hero","title":"Simple Database Migrations","estimatedTimeInMinutes":5,"chapter":"Simple Migrations","content":[{"type":"paragraph","inlineContent":[{"text":"Effortlessly & safely evolve your database schema using stage-by-stage migrations & Vein helper functions.","type":"text"}]}]},{"kind":"tasks","tasks":[{"title":"Migrating Schemas","contentSection":[{"kind":"contentAndMedia","mediaPosition":"trailing","content":[{"inlineContent":[{"text":"As your app grows, you will inevitably need to change your data models.","type":"text"},{"text":" ","type":"text"},{"text":"Vein handles this through explicit, compile-time typesafe migrations.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"In this guide, we will migrate from V0_0_1 to V0_0_2. During this change:"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"type":"codeVoice","code":"Post"},{"text":" remains unchanged.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"Attachment"},{"type":"text","text":" receives a new optional "},{"type":"codeVoice","code":"rating"},{"type":"text","text":" field."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A legacy class "},{"type":"codeVoice","code":"Unused"},{"type":"text","text":" is completely deleted."}]}]}],"type":"unorderedList"}]}],"stepsSection":[{"type":"step","media":null,"content":[{"inlineContent":[{"type":"text","text":"Define your next schema version. In "},{"type":"codeVoice","code":"V0_0_2"},{"type":"text","text":", we declare our updated models."},{"type":"text","text":" "},{"type":"text","text":"Note that the new property "},{"type":"codeVoice","code":"rating"},{"type":"text","text":" must be an optional value."}],"type":"paragraph"}],"caption":[],"code":"migration-schemas.swift","runtimePreview":null},{"type":"step","media":null,"content":[{"inlineContent":[{"type":"text","text":"Now, create your "},{"code":"SchemaMigrationPlan","type":"codeVoice"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"You list your supported schemas in chronological order and define the transitions in the "},{"code":"stages","type":"codeVoice"},{"type":"text","text":" array."}],"type":"paragraph"}],"caption":[],"code":"migration-stages-1.swift","runtimePreview":null},{"type":"step","media":null,"content":[{"inlineContent":[{"type":"text","text":"Inside the "},{"type":"codeVoice","code":"willMigrate"},{"type":"text","text":" phase, utilize Vein’s migration helpers."},{"type":"text","text":" "},{"type":"text","text":"Use "},{"type":"codeVoice","code":"unchangedMigration"},{"type":"text","text":" to keep a table intact, "},{"type":"codeVoice","code":"deleteMigration"},{"type":"text","text":" to drop a table, and "},{"type":"codeVoice","code":"fieldsAddedMigration"},{"type":"text","text":" to safely append the new optional column."}],"type":"paragraph"}],"caption":[],"code":"migration-stages-2.swift","runtimePreview":null}],"anchor":"Migrating-Schemas"}]},{"kind":"callToAction","title":"Complex Migrations","featuredEyebrow":"Tutorial","action":{"overridingTitle":"Get started","type":"reference","identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/ComplexMigrations","overridingTitleInlineContent":[{"type":"text","text":"Get started"}],"isActive":true},"abstract":[{"type":"text","text":"Handle structural database transformations by fetching existing models and inserting new ones."}]}],"hierarchy":{"paths":[["doc:\/\/VeinCore\/tutorials\/Table-of-Contents","doc:\/\/