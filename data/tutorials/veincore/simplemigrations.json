s\/quick-start"},"doc://VeinCore/tutorials/VeinCore/Quick-start-Xcode#ModelContainer--ManagedObjectContext":{"type":"section","abstract":[{"text":"Install VeinCore and create your first model.","type":"text"}],"identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Quick-start-Xcode#ModelContainer--ManagedObjectContext","kind":"section","role":"pseudoSymbol","url":"\/tutorials\/veincore\/quick-start-xcode#ModelContainer--ManagedObjectContext","title":"ModelContainer & ManagedObjectContext"},"doc://VeinCore/tutorials/VeinCore/CustomPersistable#Manual-Persistable":{"kind":"section","title":"Manual Persistable","abstract":[{"type":"text","text":"Make your own types persistable."}],"url":"\/tutorials\/veincore\/custompersistable#Manual-Persistable","role":"pseudoSymbol","type":"section","identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/CustomPersistable#Manual-Persistable"},"doc://VeinCore/tutorials/VeinCore/Quick-start-Xcode":{"estimatedTime":"5min","url":"\/tutorials\/veincore\/quick-start-xcode","abstract":[{"text":"Install VeinCore and create your first model.","type":"text"}],"kind":"project","type":"topic","identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Quick-start-Xcode","role":"project","title":"Quick start Xcode"},"doc://VeinCore/tutorials/VeinCore/MigrationUnitTests":{"url":"\/tutorials\/veincore\/migrationunittests","abstract":[{"type":"text","text":"Migrations are a crucial and complex operation."},{"type":"text","text":" "},{"type":"text","text":"Please please please unit test your migrations, it’s incredibly important for data integrity."}],"estimatedTime":"10min","kind":"project","title":"Unit Testing Migrations","type":"topic","identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/MigrationUnitTests","role":"project"},"doc://VeinCore/tutorials/VeinCore/SimpleMigrations#Migrating-Schemas":{"identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/SimpleMigrations#Migrating-Schemas","abstract":[{"type":"text","text":"Effortlessly & safely evolve your database schema using stage-by-stage migrations & Vein helper functions."}],"role":"pseudoSymbol","url":"\/tutorials\/veincore\/simplemigrations#Migrating-Schemas","type":"section","title":"Migrating Schemas","kind":"section"},"migration-schemas.swift":{"identifier":"migration-schemas.swift","type":"file","syntax":"swift","fileType":"swift","content":["import VeinCore","","\/\/ Our baseline schema","enum V0_0_1: VersionedSchema {","    static let version = ModelVersion(0, 0, 1)","    static let models: [any PersistentModel.Type] = [","        Post.self,","        Attachment.self,","        Unused.self","    ]","","    @Model final class Post { var title: String \/* ... *\/ }","    @Model final class Attachment { var name: String \/* ... *\/ }","    @Model final class Unused { var content: String \/* ... *\/ }","}","","\/\/ Our destination schema","enum V0_0_2: VersionedSchema {","    static let version = ModelVersion(0, 0, 2)","    static let models: [any PersistentModel.Type] = [","        Post.self,","        Attachment.self","    ]","","    @Model final class Post { var title: String }","","    @Model final class Attachment {","        var name: String","","        \/\/ New optional field allows safe column additions","        var rating: Int?","    }","}"],"highlights":[],"fileName":"Schemas.swift"},"doc://VeinCore/tutorials/VeinCore/ComplexMigrations":{"abstract":[{"text":"Handle structural database transformations by fetching existing models and inserting new ones.","type":"text"}],"type":"topic","role":"project","estimatedTime":"7min","identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/ComplexMigrations","kind":"project","url":"\/tutorials\/veincore\/complexmigrations","title":"Complex Migrations"},"doc://VeinCore/tutorials/Table-of-Contents/Unit-Testing-Migrations":{"kind":"article","identifier":"doc:\/\/VeinCore\/tutorials\/Table-of-Contents\/Unit-Testing-Migrations","title":"Unit Testing Migrations","abstract":[],"role":"article","url":"\/tutorials\/table-of-con