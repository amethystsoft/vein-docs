{"metadata":{"category":"Vein","role":"project","categoryPathComponent":"Table-of-Contents","title":"Simple Database Migrations"},"sections":[{"title":"Simple Database Migrations","content":[{"type":"paragraph","inlineContent":[{"text":"Effortlessly & safely evolve your database schema using stage-by-stage migrations & Vein helper functions.","type":"text"}]}],"chapter":"Simple Migrations","kind":"hero","estimatedTimeInMinutes":5},{"tasks":[{"title":"Migrating Schemas","contentSection":[{"kind":"contentAndMedia","mediaPosition":"trailing","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"As your app grows, you will inevitably need to change your data models."},{"type":"text","text":" "},{"type":"text","text":"Vein handles this through explicit, compile-time typesafe migrations."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"In this guide, we will migrate from V0_0_1 to V0_0_2. During this change:"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"codeVoice","code":"Post"},{"text":" remains unchanged.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"Attachment"},{"type":"text","text":" receives a new optional "},{"type":"codeVoice","code":"rating"},{"type":"text","text":" field."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"A legacy class ","type":"text"},{"code":"Unused","type":"codeVoice"},{"text":" is completely deleted.","type":"text"}]}]}]}]}],"stepsSection":[{"type":"step","content":[{"inlineContent":[{"text":"Define your next schema version. In ","type":"text"},{"type":"codeVoice","code":"V0_0_2"},{"text":", we declare our updated models.","type":"text"},{"text":" ","type":"text"},{"text":"Note that the new property ","type":"text"},{"type":"codeVoice","code":"rating"},{"text":" must be an optional value.","type":"text"}],"type":"paragraph"}],"caption":[],"media":null,"code":"migration-schemas.swift","runtimePreview":null},{"content":[{"inlineContent":[{"type":"text","text":"Now, create your "},{"code":"SchemaMigrationPlan","type":"codeVoice"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"You list your supported schemas in chronological order and define the transitions in the "},{"code":"stages","type":"codeVoice"},{"type":"text","text":" array."}],"type":"paragraph"}],"code":"migration-stages-1.swift","runtimePreview":null,"media":null,"type":"step","caption":[]},{"content":[{"inlineContent":[{"text":"Inside the ","type":"text"},{"type":"codeVoice","code":"willMigrate"},{"text":" phase, utilize Vein’s migration helpers.","type":"text"},{"text":" ","type":"text"},{"text":"Use ","type":"text"},{"type":"codeVoice","code":"unchangedMigration"},{"text":" to keep a table intact, ","type":"text"},{"type":"codeVoice","code":"deleteMigration"},{"text":" to drop a table, and ","type":"text"},{"type":"codeVoice","code":"fieldsAddedMigration"},{"text":" to safely append the new optional column.","type":"text"}],"type":"paragraph"}],"code":"migration-stages-2.swift","runtimePreview":null,"media":null,"type":"step","caption":[]}],"anchor":"Migrating-Schemas"}],"kind":"tasks"},{"title":"Complex Migrations","kind":"callToAction","featuredEyebrow":"Tutorial","action":{"overridingTitleInlineContent":[{"type":"text","text":"Get started"}],"identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/ComplexMigrations","type":"reference","isActive":true,"overridingTitle":"Get started"},"abstract":[{"type":"text","text":"Handle structural database transformations by fetching existing models and inserting new ones."}]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"variants":[{"paths":["\/tutorials\/veincore\/simplemigrations"],"traits":[{"interfaceLanguage":"swift"}]}],"identifier":{"url":"doc:\/\/VeinCore\/tutorials\/VeinCore\/SimpleMigrations","interfaceLanguage":"swift"},"kind":"project","hierarchy":{"paths":[["doc:\/\/VeinCore\/tutorials\/Table-of-Contents","doc:\/\/VeinCore\/tutorials\/Table-of-Contents\/$volume","doc:\/\/VeinCore\/tutorials\/Table-of-Contents\/Simple-Migrations"]],"reference":"doc:\/\/VeinCore\/tutorials\/Table-of-Contents","modules":[{"reference":"doc:\/\/VeinCore\/tutorials\/Table-of-Contents\/Quick-start","projects":[{"sections":[{"kind":"task","reference":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Quick-start-Swift-Package#Setup"},{"kind":"task","reference":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Quick-start-Swift-Package#Create-your-first-Model"},{"kind":"task","reference":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Quick-start-Swift-Package#ModelContainer--ManagedObjectContext"}],"reference":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Quick-start-Swift-Package"},{"reference":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Quick-start-Xcode","sections":[{"kind":"task","reference":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Quick-start-Xcode#Setup"},{"kind":"task","reference":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Quick-start-Xcode#Create-your-first-Model"},{"kind":"task","reference":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Quick-start-Xcode#ModelContainer--ManagedObjectContext"}]}]},{"reference":"doc:\/\/VeinCore\/tutorials\/Table-of-Contents\/Relationships","projects":[{"sections":[{"kind":"task","reference":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Relationships#Adding-a-relationship-to-our-model"},{"kind":"task","reference":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Relationships#Persisting--fetching-a-relationship"}],"reference":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Relationships"}]},{"reference":"doc:\/\/VeinCore\/tutorials\/Table-of-Contents\/Simple-Migrations","projects":[{"reference":"doc:\/\/VeinCore\/tutorials\/VeinCore\/SimpleMigrations","sections":[{"kind":"task","reference":"doc:\/\/VeinCore\/tutorials\/VeinCore\/SimpleMigrations#Migrating-Schemas"}]}]},{"reference":"doc:\/\/VeinCore\/tutorials\/Table-of-Contents\/Complex-Migrations","projects":[{"sections":[{"kind":"task","reference":"doc:\/\/VeinCore\/tutorials\/VeinCore\/ComplexMigrations#Writing-Custom-Migration-Logic"}],"reference":"doc:\/\/VeinCore\/tutorials\/VeinCore\/ComplexMigrations"}]}]},"references":{"migration-stages-2.swift":{"fileType":"swift","highlights":[],"identifier":"migration-stages-2.swift","fileName":"Migration.swift","syntax":"swift","content":["import VeinCore","","enum Migration: SchemaMigrationPlan {","    static var schemas: [any VersionedSchema.Type] {","        [V0_0_1.self, V0_0_2.self]","    }","    ","    static var stages: [MigrationStage] {","        [migrateV1toV2]","    }","    ","    static let migrateV1toV2 = MigrationStage.complex(","        fromVersion: V0_0_1.self,","        toVersion: V0_0_2.self,","        willMigrate: { context in","            \/\/ 1. Unchanged models must still be carried over","            try V0_0_1.Post.unchangedMigration(","                to: V0_0_2.Post.self,","                on: context","            )","            ","            \/\/ 2. Safely introduce the newly added optional fields","            try V0_0_1.Attachment.fieldsAddedMigration(","                to: V0_0_2.Attachment.self,","                on: context","            )","            ","            \/\/ 3. Drop tables\/data you no longer require","            try V0_0_1.Unused.deleteMigration(on: context)","        },","        didMigrate: nil","    )","}"],"type":"file"},"doc://VeinCore/tutorials/VeinCore/Quick-start-Swift-Package#Setup":{"kind":"section","role":"pseudoSymbol","title":"Setup","abstract":[{"type":"text","text":"Install VeinCore and create your first model."}],"type":"section","url":"\/tutorials\/veincore\/quick-start-swift-package#Setup","identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Quick-start-Swift-Package#Setup"},"doc://VeinCore/tutorials/VeinCore/Quick-start-Swift-Package#Create-your-first-Model":{"title":"Create your first Model","abstract":[{"type":"text","text":"Install VeinCore and create your first model."}],"type":"section","kind":"section","role":"pseudoSymbol","url":"\/tutorials\/veincore\/quick-start-swift-package#Create-your-first-Model","identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Quick-start-Swift-Package#Create-your-first-Model"},"doc://VeinCore/tutorials/Table-of-Contents":{"role":"overview","identifier":"doc:\/\/VeinCore\/tutorials\/Table-of-Contents","type":"topic","abstract":[{"text":"Database for apps made easy.","type":"text"}],"url":"\/tutorials\/table-of-contents","title":"Meet Vein","kind":"overview"},"doc://VeinCore/tutorials/VeinCore/Quick-start-Xcode#Setup":{"identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Quick-start-Xcode#Setup","type":"section","kind":"section","url":"\/tutorials\/veincore\/quick-start-xcode#Setup","abstract":[{"text":"Install VeinCore and create your first model.","type":"text"}],"role":"pseudoSymbol","title":"Setup"},"doc://VeinCore/tutorials/VeinCore/Relationships#Adding-a-relationship-to-our-model":{"title":"Adding a relationship to our model","kind":"section","identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Relationships#Adding-a-relationship-to-our-model","role":"pseudoSymbol","url":"\/tutorials\/veincore\/relationships#Adding-a-relationship-to-our-model","type":"section","abstract":[{"type":"text","text":"Use relationships with VeinCore."}]},"doc://VeinCore/tutorials/VeinCore/Relationships#Persisting--fetching-a-relationship":{"identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Relationships#Persisting--fetching-a-relationship","type":"section","url":"\/tutorials\/veincore\/relationships#Persisting--fetching-a-relationship","abstract":[{"type":"text","text":"Use relationships with VeinCore."}],"kind":"section","role":"pseudoSymbol","title":"Persisting & fetching a relationship"},"doc://VeinCore/tutorials/VeinCore/ComplexMigrations#Writing-Custom-Migration-Logic":{"title":"Writing Custom Migration Logic","type":"section","identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/ComplexMigrations#Writing-Custom-Migration-Logic","abstract":[{"type":"text","text":"Handle structural database transformations by fetching existing models and inserting new ones."}],"kind":"section","url":"\/tutorials\/veincore\/complexmigrations#Writing-Custom-Migration-Logic","role":"pseudoSymbol"},"doc://VeinCore/tutorials/VeinCore/Quick-start-Swift-Package":{"type":"topic","url":"\/tutorials\/veincore\/quick-start-swift-package","kind":"project","identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Quick-start-Swift-Package","role":"project","title":"Quick start Swift Package","abstract":[{"type":"text","text":"Install VeinCore and create your first model."}],"estimatedTime":"5min"},"doc://VeinCore/tutorials/VeinCore/Quick-start-Swift-Package#ModelContainer--ManagedObjectContext":{"type":"section","title":"ModelContainer & ManagedObjectContext","role":"pseudoSymbol","url":"\/tutorials\/veincore\/quick-start-swift-package#ModelContainer--ManagedObjectContext","kind":"section","identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Quick-start-Swift-Package#ModelContainer--ManagedObjectContext","abstract":[{"type":"text","text":"Install VeinCore and create your first model."}]},"doc://VeinCore/tutorials/Table-of-Contents/Complex-Migrations":{"kind":"article","identifier":"doc:\/\/VeinCore\/tutorials\/Table-of-Contents\/Complex-Migrations","url":"\/tutorials\/table-of-contents\/complex-migrations","title":"Complex Migrations","type":"topic","role":"article","abstract":[]},"doc://VeinCore/tutorials/VeinCore/SimpleMigrations":{"url":"\/tutorials\/veincore\/simplemigrations","type":"topic","kind":"project","abstract":[{"text":"Effortlessly & safely evolve your database schema using stage-by-stage migrations & Vein helper functions.","type":"text"}],"estimatedTime":"5min","role":"project","identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/SimpleMigrations","title":"Simple Database Migrations"},"doc://VeinCore/tutorials/VeinCore/Quick-start-Xcode#ModelContainer--ManagedObjectContext":{"kind":"section","title":"ModelContainer & ManagedObjectContext","type"