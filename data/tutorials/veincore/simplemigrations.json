re\/tutorials\/VeinCore\/CustomPersistable#Codable","kind":"section","abstract":[{"type":"text","text":"Make your own types persistable."}],"url":"\/tutorials\/veincore\/custompersistable#Codable","type":"section","role":"pseudoSymbol"},"migration-stages-1.swift":{"fileType":"swift","type":"file","identifier":"migration-stages-1.swift","highlights":[],"syntax":"swift","fileName":"Migration.swift","content":["import VeinCore","","enum Migration: SchemaMigrationPlan {","    static var schemas: [any VersionedSchema.Type] {","        [","            V0_0_1.self,","            V0_0_2.self","        ]","    }","    ","    static var stages: [MigrationStage] {","        [","            migrateV1toV2","        ]","    }","    ","    static let migrateV1toV2 = MigrationStage.complex(","        fromVersion: V0_0_1.self,","        toVersion: V0_0_2.self,","        willMigrate: { context in","            \/\/ Migration helpers will go here...","        },","        didMigrate: nil","    )","}"]},"doc://VeinCore/tutorials/Table-of-Contents/Custom-Persistable":{"title":"Custom Persistable","kind":"article","role":"article","url":"\/tutorials\/table-of-contents\/custom-persistable","abstract":[],"identifier":"doc:\/\/VeinCore\/tutorials\/Table-of-Contents\/Custom-Persistable","type":"topic"},"doc://VeinCore/tutorials/Table-of-Contents/Quick-start":{"role":"article","title":"Quick start","identifier":"doc:\/\/VeinCore\/tutorials\/Table-of-Contents\/Quick-start","type":"topic","kind":"article","abstract":[],"url":"\/tutorials\/table-of-contents\/quick-start"},"doc://VeinCore/tutorials/VeinCore/Quick-start-Xcode#Create-your-first-Model":{"abstract":[{"type":"text","text":"Install VeinCore and create your first model."}],"role":"pseudoSymbol","identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Quick-start-Xcode#Create-your-first-Model","url":"\/tutorials\/veincore\/quick-start-xcode#Create-your-first-Model","kind":"section","title":"Create your first Model","type":"section"},"doc://VeinCore/tutorials/VeinCore/SimpleMigrations":{"kind":"project","abstract":[{"type":"text","text":"Effortlessly & safely evolve your database schema using stage-by-stage migrations & Vein helper functions."}],"estimatedTime":"5min","role":"project","type":"topic","title":"Simple Database Migrations","identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/SimpleMigrations","url":"\/tutorials\/veincore\/simplemigrations"},"doc://VeinCore/tutorials/VeinCore/Quick-start-Swift-Package#Create-your-first-Model":{"title":"Create your first Model","role":"pseudoSymbol","abstract":[{"text":"Install VeinCore and create your first model.","type":"text"}],"identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Quick-start-Swift-Package#Create-your-first-Model","type":"section","url":"\/tutorials\/veincore\/quick-start-swift-package#Create-your-first-Model","kind":"section"},"doc://VeinCore/tutorials/VeinCore/Quick-start-Swift-Package#Setup":{"title":"Setup","type":"section","role":"pseudoSymbol","abstract":[{"type":"text","text":"Install VeinCore and create your first model."}],"kind":"section","identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Quick-start-Swift-Package#Setup","url":"\/tutorials\/veincore\/quick-start-swift-package#Setup"},"migration-schemas.swift":{"content":["import VeinCore","","\/\/ Our baseline schema","enum V0_0_1: VersionedSchema {","    static let version = ModelVersion(0, 0, 1)","    static let models: [any PersistentModel.Type] = [","        Post.self, Attachment.self, Unused.self","    ]","    ","    @Model final class Post { var title: String \/*...*\/ }","    @Model final class Attachment { var name: String \/*...*\/ }","    @Model final class Unused { var content: String \/*...*\/ }","}","","\/\/ Our destination schema","enum V0_0_2: VersionedSchema {","    static let version = ModelVersion(0, 0, 2)","    static let models: [any PersistentModel.Type] = [","        Post.self, Attachment.self","    ]","    ","    @Model final class Post { var title: String }","    ","    @Model final class Attachment {","        var name: String","        ","        \/\/ New optional field allows safe column additions","        var rating: Int?","    }","}"],"identifier":"migration-schemas.swift","fileType":"swift","syntax":"swift","highlights":[],"fileName":"Schemas.swift","type":"file"},"doc://VeinCore/tutorials/Table-of-Contents/Complex-Migrations":{"kind":"article","role":"article","type":"topic","url":"\/tutorials\/table-of-contents\/complex-migrations","abstract":[],"identifier":"doc:\/\/VeinCore\/tutorials\/Table-of-Contents\/Complex-Migrations","title":"Complex Migrations"},"doc://VeinCore/tutorials/VeinCore/Relationships":{"abstract":[{"text":"Use relationships with VeinCore.","type":"text"}],"role":"project","kind":"project","type":"topic","url":"\/tutorials\/veincore\/relationships","title":"Relationships","estimatedTime":"3min","identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Relationships"},"doc://VeinCore/tutorials/VeinCore/SimpleMigrations#Migrating-Schemas":{"role":"pseudoSymbol","url":"\/tutorials\/veincore\/simplemigrations#Migrating-Schemas","abstract":[{"text":"Effortlessly & safely evolve your database schema using stage-by-stage migrations & Vein helper functions.","type":"text"}],"kind":"section","identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/SimpleMigrations#Migrating-Schemas","title":"Migrating Schemas","type":"section"},"doc://VeinCore/tutorials/VeinCore/Quick-start-Swift-Package#ModelContainer--ManagedObjectContext":{"abstract":[{"text":"Install VeinCore and create your first model.","type":"text"}],"url":"\/tutorials\/veincore\/quick-start-swift-package#ModelContainer--ManagedObjectContext","identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Quick-start-Swift-Package#ModelContainer--ManagedObjectContext","role":"pseudoSymbol","type":"section","kind":"section","title":"ModelContainer & ManagedObjectContext"},"doc://VeinCore/tutorials/Table-of-Contents/Relationships":{"kind":"article","title":"Relationships","role":"article","type":"topic","url":"\/tutorials\/table-of-contents\/relationships","identifier":"doc:\/\/VeinCore\/tutorials\/Table-of-Contents\/Relationships","abstract":[]},"doc://VeinCore/tutorials/VeinCore/CustomPersistable#Manual-Persistable":{"url":"\/tutorials\/veincore\/custompersistable#Manual-Persistable","title":"Manual Persistable","identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/CustomPersistable#Manual-Persistable","kind":"section","abstract":[{"type":"text","text":"Make your own types persistable."}],"type":"section","role":"pseudoSymbol"},"migration-stages-2.swift":{"fileType":"swift","type":"file","identifier":"migration-stages-2.swift","highlights":[],"syntax":"swift","fileName":"Migration.swift","content":["import VeinCore","","enum Migration: SchemaMigrationPlan {","    static var schemas: [any VersionedSchema.Type] {","        [V0_0_1.self, V0_0_2.self]","    }","    ","    static var stages: [MigrationStage] {","        [migrateV1toV2]","    }","    ","    static let migrateV1toV2 = MigrationStage.complex(","        fromVersion: V0_0_1.self,","        toVersion: V0_0_2.self,","        willMigrate: { context in","            \/\/ 1. Unchanged models must still be carried over","            try V0_0_1.Post.unchangedMigration(","                to: V0_0_2.Post.self,","                on: context","            )","            ","            \/\/ 2. Safely introduce the newly added optional fields","            try V0_0_1.Attachment.fieldsAddedMigration(","                to: V0_0_2.Attachment.self,","                on: context","            )","            ","            \/\/ 3. Drop tables\/data you no longer require","            try V0_0_1.Unused.deleteMigration(on: context)","        },","        didMigrate: nil","    )","}"]},"doc://VeinCore/tutorials/VeinCore/Quick-start-Swift-Package":{"abstract":[{"type":"text","text":"Install VeinCore and create your first model."}],"type":"topic","role":"project","identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Quick-start-Swift-Package","estimatedTime":"5min","title":"Quick start Swift Package","url":"\/tutorials\/veincore\/quick-start-swift-package","kind":"project"},"doc://VeinCore/tutorials/Table-of-Contents":{"title":"Meet Vein","url":"\/tutorials\/table-of-contents","identifier":"doc:\/\/VeinCore\/tutorials\/Table-of-Contents","role":"overview","type":"topic","abstract":[{"type":"text","text":"Database for apps made easy."}],"kind":"overview"},"doc://VeinCore/tutorials/VeinCore/CustomPersistable":{"role":"project","title":"Custom Persistable","type":"topic","kind":"project","url":"\/tutorials\/veincore\/custompersistable","estimatedTime":"5min","abstract":[{"type":"text","text":"Make your own types persistable."}],"identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/CustomPersistable"},"doc://VeinCore/tutorials/VeinCore/ComplexMigrations":{"url":"\/tutorials\/veincore\/complexmigrations","type":"topic","kind":"project","role":"project","identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/ComplexMigrations","estimatedTime":"7min","abstract":[{"text":"Handle structural database transformations by fetching existing models and inserting new ones.","type":"text"}],"title":"Complex Migrations"}}}