ore\/ComplexMigrations#Writing-Custom-Migration-Logic","kind":"task"}]}],"reference":"doc:\/\/VeinCore\/tutorials\/Table-of-Contents\/Complex-Migrations"}],"reference":"doc:\/\/VeinCore\/tutorials\/Table-of-Contents"},"schemaVersion":{"minor":3,"major":0,"patch":0},"metadata":{"title":"Simple Database Migrations","role":"project","category":"Vein","categoryPathComponent":"Table-of-Contents"},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/VeinCore\/tutorials\/VeinCore\/SimpleMigrations"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/tutorials\/veincore\/simplemigrations"]}],"kind":"project","sections":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Effortlessly & safely evolve your database schema using stage-by-stage migrations & Vein helper functions."}]}],"kind":"hero","chapter":"Simple Migrations","title":"Simple Database Migrations","estimatedTimeInMinutes":5},{"kind":"tasks","tasks":[{"title":"Migrating Schemas","contentSection":[{"content":[{"inlineContent":[{"text":"As your app grows, you will inevitably need to change your data models.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Vein handles this through explicit, compile-time typesafe migrations."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"In this guide, we will migrate from V0_0_1 to V0_0_2. During this change:"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"code":"Post","type":"codeVoice"},{"text":" remains unchanged.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"Attachment","type":"codeVoice"},{"text":" receives a new optional ","type":"text"},{"code":"rating","type":"codeVoice"},{"text":" field.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A legacy class "},{"type":"codeVoice","code":"Unused"},{"type":"text","text":" is completely deleted."}]}]}]}],"kind":"contentAndMedia","mediaPosition":"trailing"}],"stepsSection":[{"runtimePreview":null,"caption":[],"media":null,"type":"step","code":"migration-schemas.swift","content":[{"inlineContent":[{"type":"text","text":"Define your next schema version. In "},{"type":"codeVoice","code":"V0_0_2"},{"type":"text","text":", we declare our updated models."},{"type":"text","text":" "},{"type":"text","text":"Note that the new property "},{"type":"codeVoice","code":"rating"},{"type":"text","text":" must be an optional value."}],"type":"paragraph"}]},{"runtimePreview":null,"caption":[],"media":null,"type":"step","code":"migration-stages-1.swift","content":[{"type":"paragraph","inlineContent":[{"text":"Now, create your ","type":"text"},{"code":"SchemaMigrationPlan","type":"codeVoice"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"You list your supported schemas in chronological order and define the transitions in the ","type":"text"},{"code":"stages","type":"codeVoice"},{"text":" array.","type":"text"}]}]},{"runtimePreview":null,"caption":[],"media":null,"type":"step","code":"migration-stages-2.swift","content":[{"type":"paragraph","inlineContent":[{"text":"Inside the ","type":"text"},{"code":"willMigrate","type":"codeVoice"},{"text":" phase, utilize Vein’s migration helpers.","type":"text"},{"text":" ","type":"text"},{"text":"Use ","type":"text"},{"code":"unchangedMigration","type":"codeVoice"},{"text":" to keep a table intact, ","type":"text"},{"code":"deleteMigration","type":"codeVoice"},{"text":" to drop a table, and ","type":"text"},{"code":"fieldsAddedMigration","type":"codeVoice"},{"text":" to safely append the new optional column.","type":"text"}]}]}],"anchor":"Migrating-Schemas"}]},{"action":{"overridingTitleInlineContent":[{"text":"Get started","type":"text"}],"isActive":true,"identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/ComplexMigrations","type":"reference","overridingTitle":"Get started"},"kind":"callToAction","abstract":[{"type":"text","text":"Handle structural database transformations by fetching existing models and inserting new ones."}],"title":"Complex Migrations","featuredEyebrow":"Tutorial"}],"references":{"doc://VeinCore/tutorials/VeinCore/Quick-start-Swift-Package#Create-your-first-Model":{"role":"pseudoSymbol","type":"section","title":"Create your first Model","identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Quick-start-Swift-Package#Create-your-first-Model","kind":"section","url":"\/tutorials\/veincore\/quick-start-swift-package#Create-your-first-Model","abstract":[{"type":"text","text":"Install VeinCore and create your first model."}]},"doc://VeinCore/tutorials/VeinCore/Quick-start-Xcode#ModelContainer--ManagedObjectContext":{"identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Quick-start-Xcode#ModelContainer--ManagedObjectContext","kind":"section","role":"pseudoSymbol","abstract":[{"type":"text","text":"Install VeinCore and create your first model."}],"title":"ModelContainer & ManagedObjectContext","type":"section","url":"\/tutorials\/veincore\/quick-start-xcode#ModelContainer--ManagedObjectContext"},"doc://VeinCore/tutorials/VeinCore/Quick-start-Swift-Package":{"estimatedTime":"5min","identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Quick-start-Swift-Package","kind":"project","url":"\/tutorials\/veincore\/quick-start-swift-package","role":"project","type":"topic","abstract":[{"text":"Install VeinCore and create your first model.","type":"text"}],"title":"Quick start Swift Package"},"doc://VeinCore/tutorials/VeinCore/ComplexMigrations":{"estimatedTime":"7min","title":"Complex Migrations","type":"topic","kind":"project","abstract":[{"text":"Handle structural database transformations by fetching existing models and inserting new ones.","type":"text"}],"identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/ComplexMigrations","url":"\/tutorials\/veincore\/complexmigrations","role":"project"},"doc://VeinCore/tutorials/VeinCore/Quick-start-Swift-Package#ModelContainer--ManagedObjectContext":{"role":"pseudoSymbol","abstract":[{"type":"text","text":"Install VeinCore and create your first model."}],"url":"\/tutorials\/veincore\/quick-start-swift-package#ModelContainer--ManagedObjectContext","title":"ModelContainer & ManagedObjectContext","type":"section","kind":"section","identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Quick-start-Swift-Package#ModelContainer--ManagedObjectContext"},"migration-schemas.swift":{"fileType":"swift","syntax":"swift","type":"file","content":["import VeinCore","","\/\/ Our baseline schema","enum V0_0_1: VersionedSchema {","    static let version = ModelVersion(0, 0, 1)","    static let models: [any PersistentModel.Type] = [","        Post.self, Attachment.self, Unused.self","    ]","    ","    @Model final class Post { var title: String \/*...*\/ }","    @Model final class Attachment { var name: String \/*...*\/ }","    @Model final class Unused { var content: String \/*...*\/ }","}","","\/\/ Our destination schema","enum V0_0_2: VersionedSchema {","    static let version = ModelVersion(0, 0, 2)","    static let models: [any PersistentModel.Type] = [","        Post.self, Attachment.self","    ]","    ","    @Model final class Post { var title: String }","    ","    @Model final class Attachment {","        var name: String","        ","        \/\/ New optional field allows safe column additions","        var rating: Int?","    }","}"],"fileName":"Schemas.swift","highlights":[],"identifier":"migration-schemas.swift"},"doc://VeinCore/tutorials/VeinCore/Quick-start-Xcode#Create-your-first-Model":{"kind":"section","type":"section","abstract":[{"type":"text","text":"Install VeinCore and create your first model."}],"url":"\/tutorials\/veincore\/quick-start-xcode#Create-your-first-Model","identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Quick-start-Xcode#Create-your-first-Model","title":"Create your first Model","role":"pseudoSymbol"},"migration-stages-1.swift":{"fileName":"Migration.swift","syntax":"swift","identifier":"migration-stages-1.swift","fileType":"swift","content":["import VeinCore","","enum Migration: SchemaMigrationPlan {","    static var schemas: [any VersionedSchema.Type] {","        [","            V0_0_1.self,","            V0_0_2.self","        ]","    }","    ","    static var stages: [MigrationStage] {","        [","            migrateV1toV2","        ]","    }","    ","    static let migrateV1toV2 = MigrationStage.complex(","        fromVersion: V0_0_1.self,","        toVersion: V0_0_2.self,","        willMigrate: { context in","            \/\/ Migration helpers will go here...","        },","        didMigrate: nil","    )","}"],"type":"file","highlights":[]},"doc://VeinCore/tutorials/VeinCore/Relationships":{"title":"Relationships","abstract":[{"type":"text","text":"Use relationships with VeinCore."}],"role":"project","identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Relationships","kind":"project","type":"topic","url":"\/tutorials\/veincore\/relationships","estimatedTime":"3min"},"doc://VeinCore/tutorials/Table-of-Contents":{"title":"Meet Vein","type":"topic","kind":"overview","role":"overview","identifier":"doc:\/\/VeinCore\/tutorials\/Table-of-Contents","url":"\/tutorials\/table-of-contents","abstract":[{"type":"text","text":"Database for apps made easy."}]},"doc://VeinCore/tutorials/VeinCore/Relationships#Adding-a-relationship-to-our-model":{"identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Relationships#Adding-a-relationship-to-our-model","kind":"section","abstract":[{"type":"text","text":"Use relationships with VeinCore."}],"role":"pseudoSymbol","url":"\/tutorials\/veincore\/relationships#Adding-a-relationship-to-our-model","type":"section","title":"Adding a relationship to our model"},"doc://VeinCore/tutorials/VeinCore/ComplexMigrations#Writing-Custom-Migration-Logic":{"type":"section","kind":"section","abstract":[{"text":"Handle structural database transformations by fetching existing models and inserting new ones.","type":"text"}],"title":"Writing Custom Migration Logic","r