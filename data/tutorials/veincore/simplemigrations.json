{"metadata":{"category":"Vein","categoryPathComponent":"Table-of-Contents","role":"project","title":"Simple Database Migrations"},"sections":[{"chapter":"Simple Migrations","title":"Simple Database Migrations","kind":"hero","estimatedTimeInMinutes":5,"content":[{"inlineContent":[{"type":"text","text":"Effortlessly & safely evolve your database schema using stage-by-stage migrations & Vein helper functions."}],"type":"paragraph"}]},{"kind":"tasks","tasks":[{"title":"Migrating Schemas","contentSection":[{"kind":"contentAndMedia","mediaPosition":"trailing","content":[{"inlineContent":[{"type":"text","text":"As your app grows, you will inevitably need to change your data models."},{"type":"text","text":" "},{"type":"text","text":"Vein handles this through explicit, compile-time typesafe migrations."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"In this guide, we will migrate from V0_0_1 to V0_0_2. During this change:"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"codeVoice","code":"Post"},{"text":" remains unchanged.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"Attachment"},{"type":"text","text":" receives a new optional "},{"type":"codeVoice","code":"rating"},{"type":"text","text":" field."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"A legacy class ","type":"text"},{"type":"codeVoice","code":"Unused"},{"text":" is completely deleted.","type":"text"}]}]}]}]}],"stepsSection":[{"runtimePreview":null,"caption":[],"content":[{"inlineContent":[{"type":"text","text":"Define your next schema version. In "},{"type":"codeVoice","code":"V0_0_2"},{"type":"text","text":", we declare our updated models."},{"type":"text","text":" "},{"type":"text","text":"Note that the new property "},{"type":"codeVoice","code":"rating"},{"type":"text","text":" must be an optional value."}],"type":"paragraph"}],"type":"step","media":null,"code":"migration-schemas.swift"},{"runtimePreview":null,"caption":[],"content":[{"inlineContent":[{"type":"text","text":"Now, create your "},{"type":"codeVoice","code":"SchemaMigrationPlan"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"You list your supported schemas in chronological order and define the transitions in the "},{"type":"codeVoice","code":"stages"},{"type":"text","text":" array."}],"type":"paragraph"}],"type":"step","media":null,"code":"migration-stages-1.swift"},{"runtimePreview":null,"caption":[],"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Inside the "},{"type":"codeVoice","code":"willMigrate"},{"type":"text","text":" phase, utilize Vein’s migration helpers."},{"type":"text","text":" "},{"type":"text","text":"Use "},{"type":"codeVoice","code":"unchangedMigration"},{"type":"text","text":" to keep a table intact, "},{"type":"codeVoice","code":"deleteMigration"},{"type":"text","text":" to drop a table, and "},{"type":"codeVoice","code":"fieldsAddedMigration"},{"type":"text","text":" to safely append the new optional column."}]}],"type":"step","media":null,"code":"migration-stages-2.swift"}],"anchor":"Migrating-Schemas"}]},{"title":"Complex Migrations","action":{"type":"reference","overridingTitleInlineContent":[{"type":"text","text":"Get started"}],"identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/ComplexMigrations","isActive":true,"overridingTitle":"Get started"},"featuredEyebrow":"Tutorial","abstract":[{"type":"text","text":"Handle structural database transformations by fetching existing models and inserting new ones."}],"kind":"callToAction"}],"variants":[{"paths":["\/tutorials\/veincore\/simplemigrations"],"traits":[{"interfaceLanguage":"swift"}]}],"schemaVersion":{"major":0,"patch":0,"minor":3},"identifier":{"url":"doc:\/\/VeinCore\/tutorials\/VeinCore\/SimpleMigrations","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc:\/\/VeinCore\/tutorials\/Table-of-Contents","doc:\/\/VeinCore\/tutorials\/Table-of-Contents\/$volume","doc:\/\/VeinCore\/tutorials\/Table-of-Contents\/Simple-Migrations"]],"modules":[{"projects":[{"reference":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Quick-start-Swift-Package","sections":[{"kind":"task","reference":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Quick-start-Swift-Package#Setup"},{"kind":"task","reference":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Quick-start-Swift-Package#Create-your-first-Model"},{"kind":"task","reference":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Quick-start-Swift-Package#ModelContainer--ManagedObjectContext"}]},{"reference":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Quick-start-Xcode","sections":[{"reference":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Quick-start-Xcode#Setup","kind":"task"},{"reference":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Quick-start-Xcode#Create-your-first-Model","kind":"task"},{"reference":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Quick-start-Xcode#ModelContainer--ManagedObjectContext","kind":"task"}]}],"reference":"doc:\/\/VeinCore\/tutorials\/Table-of-Contents\/Quick-start"},{"projects":[{"reference":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Relationships","sections":[{"reference":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Relationships#Adding-a-relationship-to-our-model","kind":"task"},{"reference":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Relationships#Persisting--fetching-a-relationship","kind":"task"}]}],"reference":"doc:\/\/VeinCore\/tutorials\/Table-of-Contents\/Relationships"},{"projects":[{"reference":"doc:\/\/VeinCore\/tutorials\/VeinCore\/SimpleMigrations","sections":[{"kind":"task","reference":"doc:\/\/VeinCore\/tutorials\/VeinCore\/SimpleMigrations#Migrating-Schemas"}]}],"reference":"doc:\/\/VeinCore\/tutorials\/Table-of-Contents\/Simple-Migrations"},{"projects":[{"sections":[{"reference":"doc:\/\/VeinCore\/tutorials\/VeinCore\/ComplexMigrations#Writing-Custom-Migration-Logic","kind":"task"}],"reference":"doc:\/\/VeinCore\/tutorials\/VeinCore\/ComplexMigrations"}],"reference":"doc:\/\/VeinCore\/tutorials\/Table-of-Contents\/Complex-Migrations"}],"reference":"doc:\/\/VeinCore\/tutorials\/Table-of-Contents"},"kind":"project","references":{"migration-stages-2.swift":{"syntax":"swift","identifier":"migration-stages-2.swift","fileType":"swift","type":"file","content":["import VeinCore","","enum Migration: SchemaMigrationPlan {","    static var schemas: [any VersionedSchema.Type] {","        [V0_0_1.self, V0_0_2.self]","    }","    ","    static var stages: [MigrationStage] {","        [migrateV1toV2]","    }","    ","    static let migrateV1toV2 = MigrationStage.complex(","        fromVersion: V0_0_1.self,","        toVersion: V0_0_2.self,","        willMigrate: { context in","            \/\/ 1. Unchanged models must still be carried over","            try V0_0_1.Post.unchangedMigration(","                to: V0_0_2.Post.self,","                on: context","            )","            ","            \/\/ 2. Safely introduce the newly added optional fields","            try V0_0_1.Attachment.fieldsAddedMigration(","                to: V0_0_2.Attachment.self,","                on: context","            )","            ","            \/\/ 3. Drop tables\/data you no longer require","            try V0_0_1.Unused.deleteMigration(on: context)","        },","        didMigrate: nil","    )","}"],"highlights":[],"fileName":"Migration.swift"},"doc://VeinCore/tutorials/Table-of-Contents/Relationships":{"role":"article","identifier":"doc:\/\/VeinCore\/tutorials\/Table-of-Contents\/Relationships","type":"topic","abstract":[],"title":"Relationships","kind":"article","url":"\/tutorials\/table-of-contents\/relationships"},"doc://VeinCore/tutorials/VeinCore/Quick-start-Swift-Package#Setup":{"type":"section","role":"pseudoSymbol","title":"Setup","identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Quick-start-Swift-Package#Setup","url":"\/tutorials\/veincore\/quick-start-swift-package#Setup","kind":"section","abstract":[{"type":"text","text":"Install VeinCore and create your first model."}]},"doc://VeinCore/tutorials/VeinCore/SimpleMigrations":{"abstract":[{"text":"Effortlessly & safely evolve your database schema using stage-by-stage migrations & Vein helper functions.","type":"text"}],"identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/SimpleMigrations","url":"\/tutorials\/veincore\/simplemigrations","title":"Simple Database Migrations","role":"project","type":"topic","estimatedTime":"5min","kind":"project"},"doc://VeinCore/tutorials/Table-of-Contents/Quick-start":{"title":"Quick start","kind":"article","role":"article","url":"\/tutorials\/table-of-contents\/quick-start","type":"topic","abstract":[],"identifier":"doc:\/\/VeinCore\/tutorials\/Table-of-Contents\/Quick-start"},"doc://VeinCore/tutorials/VeinCore/Quick-start-Xcode#Create-your-first-Model":{"role":"pseudoSymbol","identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Quick-start-Xcode#Create-your-first-Model","kind":"section","title":"Create your first Model","type":"section","abstract":[{"text":"Install VeinCore and create your first model.","type":"text"}],"url":"\/tutorials\/veincore\/quick-start-xcode#Create-your-first-Model"},"doc://VeinCore/tutorials/VeinCore/Quick-start-Xcode#ModelContainer--ManagedObjectContext":{"title":"ModelContainer & ManagedObjectContext","identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Quick-start-Xcode#ModelContainer--ManagedObjectContext","kind":"section","type":"section","abstract":[{"type":"text","text":"Install VeinCore and create your first model."}],"url":"\/tutorials\/veincore\/quick-start-xcode#ModelContainer--ManagedObjectContext","role":"pseudoSymbol"},"migration-schemas.swift":{"content":["import VeinCore","","\/\/ Our baseline schema","enum V0_0_1: VersionedSchema {","    static let version = ModelVersion(0, 0, 1)","    static let models: [any PersistentModel.Type] = [","        Post.self, Attachment.self, Unused.self","    ]","    ","    @Model final class Post { var title: String \/*...*\/ }","    @Model final class Attachment { var name: String \/*...*\/ }","    @Model final class Unused { var content: String \/*...*\/ }","}","","\/\/ Our destination schema","enum V0_0_2: VersionedSchema {","    static let version = ModelVersion(0, 0, 2)","    static let models: [any PersistentModel.Type] = [","        Post.self, Attachment.self","    ]","    ","    @Model final class Post { var title: String }","    ","    @Model final class Attachment {","        var name: String","        ","        \/\/ New optional field allows safe column additions","        var rating: Int?","    }","}"],"fileName":"Schemas.swift","type":"file","identifier":"migration-schemas.swift","highlights":[],"fileType":"swift","syntax":"swift"},"doc://VeinCore/tutorials/Table-of-Contents":{"role":"overview","kind":"overview","abstract":[{"type":"text","text":"Database for apps made easy."}],"identifier":"doc:\/\/VeinCore\/tutorials\/Table-of-Contents","type":"topic","url":"\/tutorials\/table-of-contents","title":"Meet Vein"},"doc://VeinCore/tutorials/VeinCore/Relationships#Adding-a-relationship-to-our-model":{"role":"pseudoSymbol","identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Relationships#Adding-a-relationship-to-our-model","kind":"section","type":"section","abstract":[{"text":"Use relationships with VeinCore.","type":"text"}],"title":"Adding a relationship to our model","url":"\/tutorials\/veincore\/relationships#Adding-a-relationship-to-our-model"},"doc://VeinCore/tutorials/VeinCore/Relationships#Persisting--fetching-a-relationship":{"role":"pseudoSymbol","identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Relationships#Persisting--fetching-a-relationship","kind":"section","type":"section","abstract":[{"type":"text","text":"Use relationships with VeinCore."}],"title":"Persisting & fetching a relationship","url":"\/tutorials\/veincore\/relationships#Persisting--fetching-a-relationship"},"doc://VeinCore/tutorials/VeinCore/Quick-start-Swift-Package#ModelContainer--ManagedObjectContext":{"title":"ModelContainer & ManagedObjectContext","type":"section","identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Quick-start-Swift-Package#ModelContainer--ManagedObjectContext","kind":"section","url":"\/tutorials\/veincore\/quick-start-swift-package#ModelContainer--ManagedObjectContext","abstract":[{"text":"Install VeinCore and create your first model.","type":"text"}],"role":"pseudoSymbol"},"doc://VeinCore/tutorials/VeinCore/ComplexMigrations":{"estimatedTime":"7min","role":"project","kind":"project","url":"\/tutorials\/veincore\/complexmigrations","type":"topic","title":"Complex Migrations","abstract":[{"type":"text","text":"Handle structural database transformations by fetching existing models and inserting new ones."}],"identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/ComplexMigrations"},"doc://VeinCore/tutorials/VeinCore/ComplexMigrations#Writing-Custom-Migration-Logic":{"kind":"section","title":"Writing Custom Migration Logic","url":"\/tutorials\/veincore\/complexmigrations#Writing-Custom-Migration-Logic","identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/ComplexMigrations#Writing-Custom-Migration-Logic","abstract":[{"text":"Handle structural database transformations by fetching existing models and inserting new ones.","type":"text"}],"role":"pseudoSymbol","type":"section"},"migration-stages-1.swift":{"content":["import VeinCore","","enum Migration: SchemaMigrationPlan {","    static var schemas: [any VersionedSchema.Type] {","        [","            V0_0_1.self,","            V0_0_2.self","        ]","    }","    ","    static var stages: [MigrationStage] {","        [","            migrateV1toV2","        ]","    }","    ","    static let migrateV1toV2 = MigrationStage.complex(","        fromVersion: V0_0_1.self,","        toVersion: V0_0_2.self,","        willMigrate: { context in","            \/\/ Migration helpers will go here...","        },","        didMigrate: nil","    )","}"],"fileName":"Migration.swift","type":"file","identifier":"migration-stages-1.swift","h