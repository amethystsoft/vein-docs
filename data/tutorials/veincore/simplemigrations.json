pe":"paragraph"},{"inlineContent":[{"text":"In this guide, we will migrate from V0_0_1 to V0_0_2. During this change:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"code":"Post","type":"codeVoice"},{"type":"text","text":" remains unchanged."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"Attachment","type":"codeVoice"},{"type":"text","text":" receives a new optional "},{"code":"rating","type":"codeVoice"},{"type":"text","text":" field."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"A legacy class ","type":"text"},{"code":"Unused","type":"codeVoice"},{"text":" is completely deleted.","type":"text"}]}]}],"type":"unorderedList"}]}],"anchor":"Migrating-Schemas","title":"Migrating Schemas","stepsSection":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Define your next schema version. In "},{"type":"codeVoice","code":"V0_0_2"},{"type":"text","text":", we declare our updated models."},{"type":"text","text":" "},{"type":"text","text":"Note that the new property "},{"type":"codeVoice","code":"rating"},{"type":"text","text":" must be an optional value."}]}],"type":"step","media":null,"caption":[],"code":"migration-schemas.swift","runtimePreview":null},{"content":[{"inlineContent":[{"type":"text","text":"Now, create your "},{"type":"codeVoice","code":"SchemaMigrationPlan"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"You list your supported schemas in chronological order and define the transitions in the "},{"type":"codeVoice","code":"stages"},{"type":"text","text":" array."}],"type":"paragraph"}],"type":"step","media":null,"caption":[],"code":"migration-stages-1.swift","runtimePreview":null},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Inside the "},{"code":"willMigrate","type":"codeVoice"},{"type":"text","text":" phase, utilize Vein’s migration helpers."},{"type":"text","text":" "},{"type":"text","text":"Use "},{"code":"unchangedMigration","type":"codeVoice"},{"type":"text","text":" to keep a table intact, "},{"code":"deleteMigration","type":"codeVoice"},{"type":"text","text":" to drop a table, and "},{"code":"fieldsAddedMigration","type":"codeVoice"},{"type":"text","text":" to safely append the new optional column."}]}],"type":"step","media":null,"caption":[],"code":"migration-stages-2.swift","runtimePreview":null}]}]},{"kind":"callToAction","featuredEyebrow":"Tutorial","title":"Complex Migrations","abstract":[{"text":"Handle structural database transformations by fetching existing models and inserting new ones.","type":"text"}],"action":{"isActive":true,"overridingTitle":"Get started","type":"reference","identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/ComplexMigrations","overridingTitleInlineContent":[{"text":"Get started","type":"text"}]}}],"metadata":{"category":"Vein","role":"project","categoryPathComponent":"Table-of-Contents","title":"Simple Database Migrations"},"schemaVersion":{"patch":0,"major":0,"minor":3},"kind":"project","variants":[{"paths":["\/tutorials\/veincore\/simplemigrations"],"traits":[{"interfaceLanguage":"swift"}]}],"references":{"doc://VeinCore/tutorials/VeinCore/CustomPersistable":{"url":"\/tutorials\/veincore\/custompersistable","type":"topic","identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/CustomPersistable","role":"project","abstract":[{"type":"text","text":"Make your own types persistable."}],"estimatedTime":"5min","title":"Custom Persistable","kind":"project"},"doc://VeinCore/tutorials/VeinCore/Quick-start-Swift-Package":{"abstract":[{"text":"Install VeinCore and create your first model.","type":"text"}],"title":"Quick start Swift Package","identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Quick-start-Swift-Package","role":"project","url":"\/tutorials\/veincore\/quick-start-swift-package","estimatedTime":"5min","type":"topic","kind":"project"},"doc://VeinCore/tutorials/VeinCore/Quick-start-Swift-Package#Setup":{"abstract":[{"text":"Install VeinCore and create your first model.","type":"text"}],"title":"Setup","identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Quick-start-Swift-Package#Setup","role":"pseudoSymbol","url":"\/tutorials\/veincore\/quick-start-swift-package#Setup","type":"section","kind":"section"},"doc://VeinCore/tutorials/VeinCore/Quick-start-Swift-Package#Create-your-first-Model":{"abstract":[{"type":"text","text":"Install VeinCore and create your first model."}],"title":"Create your first Model","role":"pseudoSymbol","identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Quick-start-Swift-Package#Create-your-first-Model","type":"section","kind":"section","url":"\/tutorials\/veincore\/quick-start-swift-package#Create-your-first-Model"},"doc://VeinCore/tutorials/VeinCore/Relationships":{"url":"\/tutorials\/veincore\/relationships","title":"Relationships","identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Relationships","role":"project","abstract":[{"type":"text","text":"Use relationships with VeinCore."}],"type":"topic","estimatedTime":"3min","kind":"project"},"doc://VeinCore/tutorials/VeinCore/Relationships#Persisting--fetching-a-relationship":{"kind":"section","url":"\/tutorials\/veincore\/relationships#Persisting--fetching-a-relationship","abstract":[{"type":"text","text":"Use relationships with VeinCore."}],"title":"Persisting & fetching a relationship","type":"section","role":"pseudoSymbol","identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Relationships#Persisting--fetching-a-relationship"},"doc://VeinCore/tutorials/VeinCore/MigrationUnitTests#The-migration-we-are-going-to-test":{"title":"The migration we are going to test:","abstract":[{"type":"text","text":"Migrations are a crucial and complex operation."},{"type":"text","text":" "},{"type":"text","text":"Please please please unit test your migrations, it’s incredibly important for data integrity."}],"url":"\/tutorials\/veincore\/migrationunittests#The-migration-we-are-going-to-test","kind":"section","type":"section","role":"pseudoSymbol","identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/MigrationUnitTests#The-migration-we-are-going-to-test"},"doc://VeinCore/tutorials/VeinCore/MigrationUnitTests#Unit-Testing":{"url":"\/tutorials\/veincore\/migrationunittests#Unit-Testing","title":"Unit Testing","identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/MigrationUnitTests#Unit-Testing","role":"pseudoSymbol","abstract":[{"text":"Migrations are a crucial and complex operation.","type":"text"},{"text":" ","type":"text"},{"text":"Please please please unit test your migrations, it’s incredibly important for data integrity.","type":"text"}],"type":"section","kind":"section"},"migration-stages-2.swift":{"highlights":[],"syntax":"swift","identifier":"migration-stages-2.swift","type":"file","fileType":"swift","content":["import VeinCore","","enum Migration: SchemaMigrationPlan {","    static var schemas: [any VersionedSchema.Type] {","        [V0_0_1.self, V0_0_2.self]","    }","","    static var stages: [MigrationStage] {","        [migrateV1toV2]","    }","","    static let migrateV1toV2 = MigrationStage.complex(","        fromVersion: V0_0_1.self,","        toVersion: V0_0_2.self,","        willMigrate: { context in","            \/\/ 1. Unchanged models must still be carried over","            try V0_0_1.Post.unchangedMigration(","                to: V0_0_2.Post.self,","                on: context","            )","","            \/\/ 2. Safely introduce the newly added optional fields","            try V0_0_1.Attachment.fieldsAddedMigration(","                to: V0_0_2.Attachment.self,","                on: context","            )","","            \/\/ 3. Drop tables\/data you no longer require","            try V0_0_1.Unused.deleteMigration(on: context)","        },","        didMigrate: nil","    )","}"],"fileName":"Migration.swift"},"doc://VeinCore/tutorials/VeinCore/Quick-start-Swift-Package#ModelContainer--ManagedObjectContext":{"identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Quick-start-Swift-Package#ModelContainer--ManagedObjectContext","role":"pseudoSymbol","type":"section","abstract":[{"type":"text","text":"Install VeinCore and create your first model."}],"kind":"section","url":"\/tutorials\/veincore\/quick-start-swift-package#ModelContainer--ManagedObjectContext","title":"ModelContainer & ManagedObjectContext"},"doc://VeinCore/tutorials/VeinCore/Quick-start-Xcode#Create-your-first-Model":{"kind":"section","title":"Create your first Model","type":"section","abstract":[{"text":"Install VeinCore and create your first model.","type":"text"}],"url":"\/tutorials\/veincore\/quick-start-xcode#Create-your-first-Model","identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Quick-start-Xcode#Create-your-first-Model","role":"pseudoSymbol"},"doc://VeinCore/tutorials/Table-of-Contents/Custom-Persistable":{"kind":"article","identifier":"doc:\/\/VeinCore\/tutorials\/Table-of-Contents\/Custom-Persistable","title":"Custom Persistable","abstract":[],"role":"article","url":"\/tutorials\/table-of-contents\/custom-persistable","type":"topic"},"migration-stages-1.swift":{"fileName":"Migration.swift","fileType":"swift","content":["import VeinCore","","enum Migration: SchemaMigrationPlan {","    static var schemas: [any VersionedSchema.Type] {","        [","            V0_0_1.self,","            V0_0_2.self","        ]","    }","","    static var stages: [MigrationStage] {","        [","            migrateV1toV2","        ]","    }","","    static let migrateV1toV2 = MigrationStage.complex(","        fromVersion: V0_0_1.self,","        toVersion: V0_0_2.self,","        willMigrate: { context in","            \/\/ Migration helpers will go here...","        },","        didMigrate: nil","    )","}"],"type":"file","identifier":"migration-stages-1.swift","syntax":"swift","highlights":[]},"doc://VeinCore/tutorials/VeinCore/MigrationUnitTests#Unit-Testing-full-migration-chain":{"abstract":[{"type":"text","text":"Migrations are a crucial and complex operation."}