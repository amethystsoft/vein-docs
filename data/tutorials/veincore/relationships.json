t":[{"type":"paragraph","inlineContent":[{"type":"text","text":"To connect them, we add the @Relationship macro to both sides."},{"type":"text","text":" "},{"type":"text","text":"One side specifies an inverse parameter, now both know the opposing side’s corresponding field name."},{"type":"text","text":" "},{"type":"text","text":"We also want attachments to get deleted when a post gets deleted,"},{"type":"text","text":" "},{"type":"text","text":"that’s defined through the cascade deleteRule."}]}],"type":"step","code":"relationships-2.swift"}],"anchor":"Adding-a-relationship-to-our-model","title":"Adding a relationship to our model"},{"contentSection":[{"content":[{"inlineContent":[{"type":"text","text":"Like any other field, relationships work by setting or getting the parameter they are defined on."}],"type":"paragraph"}],"mediaPosition":"trailing","kind":"contentAndMedia"}],"stepsSection":[{"runtimePreview":null,"code":"relationship-use-1.swift","type":"step","caption":[],"content":[{"inlineContent":[{"type":"text","text":"Create instances of "},{"type":"codeVoice","code":"Post"},{"type":"text","text":" and "},{"type":"codeVoice","code":"Attachment"},{"type":"text","text":"."}],"type":"paragraph"}],"media":null},{"runtimePreview":null,"code":"relationship-use-2.swift","type":"step","caption":[],"content":[{"inlineContent":[{"text":"Insert one post into context, then add the attachment.","type":"text"}],"type":"paragraph"}],"media":null},{"runtimePreview":null,"code":"relationship-use-3.swift","type":"step","caption":[],"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"To read them, just access the property and do whatever you need."}]}],"media":null}],"title":"Persisting & fetching a relationship","anchor":"Persisting--fetching-a-relationship"}],"kind":"tasks"},{"action":{"overridingTitle":"Get started","isActive":true,"identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/SimpleMigrations","overridingTitleInlineContent":[{"text":"Get started","type":"text"}],"type":"reference"},"kind":"callToAction","abstract":[{"text":"Effortlessly & safely evolve your database schema using stage-by-stage migrations & Vein helper functions.","type":"text"}],"featuredEyebrow":"Tutorial","title":"Simple Database Migrations"}],"schemaVersion":{"major":0,"minor":3,"patch":0},"kind":"project","references":{"doc://VeinCore/tutorials/VeinCore/SimpleMigrations":{"role":"project","identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/SimpleMigrations","url":"\/tutorials\/veincore\/simplemigrations","estimatedTime":"5min","kind":"project","abstract":[{"type":"text","text":"Effortlessly & safely evolve your database schema using stage-by-stage migrations & Vein helper functions."}],"title":"Simple Database Migrations","type":"topic"},"relationships-1.swift":{"content":["import Foundation","import VeinCore","","enum V0_0_1: VersionedSchema {","    static let version = ModelVersion(0, 0, 1)","    static let models: [any PersistentModel.Type] = [","        Post.self, Attachment.self","    ]","    ","    @Model","    final class Post {","        var title: String","        var content: String","        ","        @LazyField","        var attachment: Data?","        ","        init(title: String, content: String) {","            self.title = title","            self.content = content","        }","    }","    ","    @Model","    final class Attachment {","        var name: String","        var fileType: FileType","        var sizeMiB: Double","        ","        @LazyField","        var data: Data?","        ","        init(name: String, fileType: FileType, data: Data) {","            self.name = name","            self.fileType = fileType","            self.sizeMiB = Double(data.count) \/ 1024 \/ 1024","            self.data = data","        }","        ","        enum FileType: String, RawRepresentablePersistable {","            case png","            case jpg","            case gif","            case swift","            \/\/ ...","        }","    }","}","","typealias Post = V0_0_1.Post","typealias Attachment = V0_0_1.Attachment","","enum Migration: SchemaMigrationPlan {","    static let schemas: [VersionedSchema.Type] = [","        V0_0_1.self","    ]","    ","    static let stages: [MigrationStage] = []","}"],"identifier":"relationships-1.swift","type":"file","fileName":"Post.swift","syntax":"swift","highlights":[],"fileType":"swift"},"relationship-use-3.swift":{"content":["import Foundation","import VeinCore","","func tryRelationships(context: ManagedObjectContext) throws {","    let post = Post(","        title: \"How to use Vein relationships?\",","        content: \"Again, it's pretty easy.\"","    )","    let attachment = Attachment(","        name: \"ExampleFile\",","        fileType: .swift,","        data: Data([UInt8](repeating: 0, count: 1024 * 1024)) \/\/ very real swift file","    )","    ","    \/\/ Relationships only work with context.","    try context.insert(post)","    \/\/ Added models get inserted automatically.","    post.attachments.append(attachment)","}","","func getSwiftAttachments(of post: Post) -> [Attachment] {","    post.attachments.filter { $0.fileType == .swift }","}"],"syntax":"swift","fileName":"Post.swift","identifier":"relationship-use-3.swift","fileType":"swift","type":"file","highlights":[]},"doc://VeinCore/tutorials/VeinCore/CustomPersistable#Manual-Persistable":{"abstract":[{"text":"Make your own types persistable.","type":"text"}],"identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/CustomPersistable#Manual-Persistable","type":"section","url":"\/tutorials\/veincore\/custompersistable#Manual-Persistable","kind":"section","title":"Manual Persistable","role":"pseudoSymbol"},"doc://VeinCore/tutorials/VeinCore/Quick-start-Swift-Package":{"kind":"project","type":"topic","url":"\/tutorials\/veincore\/quick-start-swift-package","identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Quick-start-Swift-Package","title":"Quick start Swift Package","abstract":[{"text":"In