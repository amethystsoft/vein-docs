: SchemaMigrationPlan {","    static let schemas: [VersionedSchema.Type] = [","        V0_0_1.self","    ]","    ","    static let stages: [MigrationStage] = []","}"],"identifier":"relationships-2.swift","type":"file","fileName":"Post.swift","syntax":"swift","highlights":[],"fileType":"swift"},"doc://VeinCore/tutorials/Table-of-Contents/Relationships":{"kind":"article","role":"article","title":"Relationships","abstract":[],"type":"topic","identifier":"doc:\/\/VeinCore\/tutorials\/Table-of-Contents\/Relationships","url":"\/tutorials\/table-of-contents\/relationships"},"relationship-use-1.swift":{"content":["import Foundation","import VeinCore","","func tryRelationships(context: ManagedObjectContext) throws {","    let post = Post(","        title: \"How to use Vein relationships?\",","        content: \"Again, it's pretty easy.\"","    )","    let attachment = Attachment(","        name: \"ExampleFile\",","        fileType: .swift,","        data: Data([UInt8](repeating: 0, count: 1024 * 1024)) \/\/ very real swift file","    )","}"],"identifier":"relationship-use-1.swift","type":"file","fileName":"Post.swift","syntax":"swift","highlights":[],"fileType":"swift"},"doc://VeinCore/tutorials/Table-of-Contents/Complex-Migrations":{"kind":"article","role":"article","title":"Complex Migrations","abstract":[],"type":"topic","identifier":"doc:\/\/VeinCore\/tutorials\/Table-of-Contents\/Complex-Migrations","url":"\/tutorials\/table-of-contents\/complex-migrations"},"doc://VeinCore/tutorials/VeinCore/Relationships":{"url":"\/tutorials\/veincore\/relationships","abstract":[{"type":"text","text":"Use relationships with VeinCore."}],"estimatedTime":"3min","title":"Relationships","role":"project","identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Relationships","type":"topic","kind":"project"},"doc://VeinCore/tutorials/VeinCore/Relationships#Persisting--fetching-a-relationship":{"role":"pseudoSymbol","url":"\/tutorials\/veincore\/relationships#Persisting--fetching-a-relationship"