et stages: [MigrationStage] = []","}"],"syntax":"swift","fileType":"swift","identifier":"relationships-1.swift"},"doc://VeinCore/tutorials/Table-of-Contents/Simple-Migrations":{"kind":"article","type":"topic","role":"article","title":"Simple Migrations","url":"\/tutorials\/table-of-contents\/simple-migrations","abstract":[],"identifier":"doc:\/\/VeinCore\/tutorials\/Table-of-Contents\/Simple-Migrations"},"doc://VeinCore/tutorials/VeinCore/Quick-start-Xcode#ModelContainer--ManagedObjectContext":{"type":"section","abstract":[{"text":"Install VeinCore and create your first model.","type":"text"}],"identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Quick-start-Xcode#ModelContainer--ManagedObjectContext","kind":"section","role":"pseudoSymbol","url":"\/tutorials\/veincore\/quick-start-xcode#ModelContainer--ManagedObjectContext","title":"ModelContainer & ManagedObjectContext"},"doc://VeinCore/tutorials/Table-of-Contents/Quick-start":{"kind":"article","type":"topic","role":"article","title":"Quick start","abstract":[],"identifier":"doc:\/\/VeinCore\/tutorials\/Table-of-Contents\/Quick-start","url":"\/tutorials\/table-of-contents\/quick-start"},"doc://VeinCore/tutorials/VeinCore/Relationships#Adding-a-relationship-to-our-model":{"type":"section","kind":"section","identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Relationships#Adding-a-relationship-to-our-model","abstract":[{"text":"Use relationships with VeinCore.","type":"text"}],"role":"pseudoSymbol","title":"Adding a relationship to our model","url":"\/tutorials\/veincore\/relationships#Adding-a-relationship-to-our-model"},"doc://VeinCore/tutorials/VeinCore/MigrationUnitTests#Unit-Testing":{"url":"\/tutorials\/veincore\/migrationunittests#Unit-Testing","title":"Unit Testing","identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/MigrationUnitTests#Unit-Testing","role":"pseudoSymbol","abstract":[{"text":"Migrations are a crucial and complex operation.","type":"text"},{"text":" ","type":"text"},{"text":"Please please pleas