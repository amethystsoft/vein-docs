presentablePersistable {","            case png","            case jpg","            case gif","            case swift","            \/\/ ...","        }","    }","}","","typealias Post = V0_0_1.Post","typealias Attachment = V0_0_1.Attachment","","enum Migration: SchemaMigrationPlan {","    static let schemas: [VersionedSchema.Type] = [","        V0_0_1.self","    ]","","    static let stages: [MigrationStage] = []","}"],"syntax":"swift","identifier":"relationships-2.swift","fileType":"swift"},"relationship-use-2.swift":{"type":"file","content":["import Foundation","import VeinCore","","func tryRelationships(context: ManagedObjectContext) throws {","    let post = Post(","        title: \"How to use Vein relationships?\",","        content: \"Again, it's pretty easy.\"","    )","    let attachment = Attachment(","        name: \"ExampleFile\",","        fileType: .swift,","        data: Data([UInt8](repeating: 0, count: 1024 * 1024)) \/\/ very real swift file","    )","","    \/\/ Relationships only work with context.","    try context.insert(post)","    \/\/ Added models get inserted automatically.","    post.attachments.append(attachment)","}"],"identifier":"relationship-use-2.swift","fileType":"swift","highlights":[],"syntax":"swift","fileName":"Post.swift"},"doc://VeinCore/tutorials/VeinCore/SimpleMigrations#Migrating-Schemas":{"identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/SimpleMigrations#Migrating-Schemas","abstract":[{"type":"text","text":"Effortlessly & safely evolve your database schema using stage-by-stage migrations & Vein helper functions."}],"role":"pseudoSymbol","url":"\/tutorials\/veincore\/simplemigrations#Migrating-Schemas","type":"section","title":"Migrating Schemas","kind":"section"},"doc://VeinCore/tutorials/VeinCore/MigrationUnitTests#The-migration-we-are-going-to-test":{"title":"The migration we are going to test:","abstract":[{"type":"text","text":"Migrations are a crucial and complex operation."},{"type":"text","text":" "},{"type":"tex