efined through the cascade deleteRule.","type":"text"}],"type":"paragraph"}],"caption":[],"code":"relationships-2.swift","runtimePreview":null,"media":null,"type":"step"}],"anchor":"Adding-a-relationship-to-our-model"},{"title":"Persisting & fetching a relationship","contentSection":[{"kind":"contentAndMedia","mediaPosition":"trailing","content":[{"inlineContent":[{"text":"Like any other field, relationships work by setting or getting the parameter they are defined on.","type":"text"}],"type":"paragraph"}]}],"stepsSection":[{"media":null,"content":[{"type":"paragraph","inlineContent":[{"text":"Create instances of ","type":"text"},{"code":"Post","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"Attachment","type":"codeVoice"},{"text":".","type":"text"}]}],"code":"relationship-use-1.swift","type":"step","caption":[],"runtimePreview":null},{"media":null,"content":[{"type":"paragraph","inlineContent":[{"text":"Insert one post into context, then add the attachment.","type":"text"}]}],"code":"relationship-use-2.swift","type":"step","caption":[],"runtimePreview":null},{"media":null,"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"To read them, just access the property and do whatever you need."}]}],"code":"relationship-use-3.swift","type":"step","caption":[],"runtimePreview":null}],"anchor":"Persisting--fetching-a-relationship"}],"kind":"tasks"},{"title":"Simple Database Migrations","abstract":[{"text":"Effortlessly & safely evolve your database schema using stage-by-stage migrations & Vein helper functions.","type":"text"}],"action":{"overridingTitle":"Get started","overridingTitleInlineContent":[{"type":"text","text":"Get started"}],"type":"reference","identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/SimpleMigrations","isActive":true},"featuredEyebrow":"Tutorial","kind":"callToAction"}],"references":{"doc://VeinCore/tutorials/VeinCore/Quick-start-Xcode#Create-your-first-Model":{"role":"pseudoSymbol","identifier":"doc:\/\/VeinCore\/tutorials\/VeinCore\/Quick-start-Xcode#Create-your-first-Model","kind":"section","title":"Create your first Model","type":"section","abstract":[{"text":"Install VeinCore and create your first model.","type":"text"}],"url":"\/tutorials\/veincore\/quick-start-xcode#Create-your-first-Model"},"relationships-1.swift":{"fileName":"Post.swift","identifier":"relationships-1.swift","syntax":"swift","fileType":"swift","highlights":[],"content":["import Foundation","import VeinCore","","enum V0_0_1: VersionedSchema {","    static let version = ModelVersion(0, 0, 1)","    static let models: [any PersistentModel.Type] = [","        Post.self, Attachment.self","    ]","    ","    @Model","    final class Post {","        var title: String","        var content: String","        ","        @LazyField","        var attachment: Data?","        ","        init(title: String, content: String) {","            self.title = title","            self.content = content","        }","    }","    ","    @Model","    final class Attachment {","        var name: String","        var fileType: FileType","        var sizeMiB: Double","        ","        @LazyField","        var data: Data?","        ","        init(name: String, fileType: FileType, data: Data) {","            self.name = name","            self.fileType = fileType","            self.sizeMiB = Double(data.count) \/ 1024 \/ 1024","            self.data = data","        }","        ","        enum FileType: String, RawRepresentablePersistable {","            case png","            case jpg","            case gif","            case swift","            \/\/ ...","        }","    }","}","","typealias Post = V0_0_1.Post","typealias Attachment = V0_0_1.Attachment","","enum Migration: SchemaMigrationPlan {","    static let schemas: [VersionedSchema.Type] = [","        V0_0_1.self","    ]","    ","    static let stages: [MigrationStage] = []","}"],"type":"file"},"doc://VeinCore/tutorials/VeinCore/ComplexMigrations#Writing-Custom-Migration-Logic